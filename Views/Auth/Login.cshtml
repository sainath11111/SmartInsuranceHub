@{
    ViewData["Title"] = "Login";
    Layout = "_LandingLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 text-center pt-5 pb-3">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-shield-lock-fill fs-2"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">Welcome Back</h3>
                    <p class="text-muted mb-0">Sign in to your Smart Insurance Hub account</p>
                </div>
                
                <div class="card-body px-5 pb-5">
                    @if(ViewBag.Error != null) {
                        <div class="alert alert-danger d-flex align-items-center rounded-3 mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>@ViewBag.Error</div>
                        </div>
                    }

                    <form method="post" action="/Auth/Login">
                        <!-- Role Selector -->
                        <div class="form-floating mb-4">
                            <select name="role" id="roleSelect" class="form-select rounded-3">
                                <option value="Customer">Customer</option>
                                <option value="Agent">Agent</option>
                                <option value="Company">Insurance Company</option>
                                <option value="Admin">Administrator</option>
                            </select>
                            <label for="roleSelect"><i class="bi bi-person-badge text-primary me-2"></i>Sign in as</label>
                        </div>
                        
                        <!-- Company Container -->
                        <div class="form-floating mb-4 d-none" id="companyContainer">
                            <select name="company_id" id="companyDropdown" class="form-select rounded-3">
                                <option value="">-- Select Your Company --</option>
                                @if (ViewBag.Companies != null)
                                {
                                    foreach (var company in ViewBag.Companies)
                                    {
                                        <option value="@company.company_id">@company.company_name</option>
                                    }
                                }
                            </select>
                            <label for="companyDropdown"><i class="bi bi-building text-primary me-2"></i>Select Company</label>
                        </div>

                        <!-- Email Input -->
                        <div class="form-floating mb-4" id="emailContainer">
                            <input type="email" id="emailInput" name="email" class="form-control rounded-3" placeholder="name@example.com" />
                            <label for="emailInput"><i class="bi bi-envelope text-primary me-2"></i>Email Address</label>
                        </div>

                        <!-- Password Input -->
                        <div class="form-floating mb-5">
                            <input type="password" id="passwordInput" name="password" class="form-control rounded-3" required placeholder="Password" />
                            <label for="passwordInput"><i class="bi bi-lock text-primary me-2"></i>Password</label>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm" style="transition: all 0.3s; letter-spacing: 0.5px;">
                            Sign In <i class="bi bi-box-arrow-in-right ms-2"></i>
                        </button>
                    </form>
                    
                    <!-- Registration Links -->
                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted small mb-3">Don't have an account?</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a href="/Auth/RegisterCustomer" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-medium">As Customer</a>
                            <a href="/Auth/RegisterAgent" class="btn btn-outline-secondary btn-sm rounded-pill px-4 fw-medium">As Agent</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.getElementById('roleSelect');
            const companyContainer = document.getElementById('companyContainer');
            const companyDropdown = document.getElementById('companyDropdown');
            const emailContainer = document.getElementById('emailContainer');
            const emailInput = document.getElementById('emailInput');

            function toggleFields() {
                if (roleSelect.value === 'Company') {
                    companyContainer.classList.remove('d-none');
                    emailContainer.classList.add('d-none');
                    companyDropdown.required = true;
                    emailInput.required = false;
                    emailInput.value = ''; 
                } else {
                    companyContainer.classList.add('d-none');
                    emailContainer.classList.remove('d-none');
                    companyDropdown.required = false;
                    emailInput.required = true;
                    companyDropdown.value = ''; 
                }
            }

            roleSelect.addEventListener('change', toggleFields);
            toggleFields();
        });
    </script>
}
