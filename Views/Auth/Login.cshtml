@{
    ViewData["Title"] = "Login";
    Layout = null; // We are building a custom split layout that doesn't need the navbar
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-split-wrapper">
    <!-- Left Side: Graphic / Branding -->
    <div class="auth-split-left">
        <div class="mb-auto">
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="40" class="me-2 rounded shadow-sm">
                <span class="fs-4 fw-bold text-dark">Smart<span class="text-primary">Insurance</span></span>
            </a>
            <a href="/" class="btn btn-outline-primary btn-sm mt-3 rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Home</a>
        </div>
        <div class="z-3">
            <h1 class="display-4 fw-bold text-secondary mb-4">Welcome back to your <span class="text-primary">secure</span> future.</h1>
            <p class="fs-5 text-muted mb-4">Log in to manage your policies, connect with agents, and safeguard everything that matters to you.</p>
        </div>
        <div class="mt-auto">
            <div class="d-flex align-items-center bg-white p-3 rounded-4 shadow-sm" style="max-width: 300px;">
                <div class="bg-primary-subtle text-primary p-2 rounded-circle me-3">
                    <i class="bi bi-shield-check fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">256-bit Encryption</h6>
                    <small class="text-muted">Your data is safe with us.</small>
                </div>
            </div>
        </div>
        
        <!-- Decorative Shapes -->
        <div class="position-absolute rounded-circle" style="width: 500px; height: 500px; background: rgba(37,99,235,0.05); top: -100px; right: -100px; z-index: 1;"></div>
        <div class="position-absolute rounded-circle" style="width: 300px; height: 300px; background: rgba(16,185,129,0.05); bottom: -50px; left: -50px; z-index: 1;"></div>
    </div>

    <!-- Right Side: Form -->
    <div class="auth-split-right">
        <div class="auth-card-inner">
            <div class="text-center mb-5 d-lg-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="48" class="rounded shadow-sm mb-3">
                <h2 class="fw-bold">Welcome Back</h2>
            </div>
            
            <h2 class="fw-bold text-dark mb-1 d-none d-lg-block">Sign In</h2>
            <p class="text-muted mb-4 d-none d-lg-block">Enter your credentials to access your account.</p>

            @if(ViewBag.Error != null) {
                <div class="alert alert-danger d-flex align-items-center border-0 rounded-3 mb-4 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-3"></i>
                    <div>@ViewBag.Error</div>
                </div>
            }

            <form method="post" action="/Auth/Login" class="needs-validation">
                <!-- Role Selector -->
                <div class="form-floating mb-3">
                    <select name="role" id="roleSelect" class="form-select border-0 shadow-sm" style="background-color: var(--bg-light);">
                        <option value="Customer">Customer</option>
                        <option value="Agent">Agent</option>
                        <option value="Company">Insurance Company</option>
                        <option value="Admin">Administrator</option>
                    </select>
                    <label for="roleSelect"><i class="bi bi-person-badge text-primary me-2"></i>Sign in as</label>
                </div>
                
                <!-- Company Dropdown (Hidden initially) -->
                <div class="form-floating mb-3 d-none" id="companyContainer">
                    <select name="company_id" id="companyDropdown" class="form-select border-0 shadow-sm" style="background-color: var(--bg-light);">
                        <option value="">-- Select Your Company --</option>
                        @if (ViewBag.Companies != null)
                        {
                            foreach (var company in ViewBag.Companies)
                            {
                                <option value="@company.company_id">@company.company_name</option>
                            }
                        }
                    </select>
                    <label for="companyDropdown"><i class="bi bi-building text-primary me-2"></i>Select Company</label>
                </div>

                <!-- Email Input -->
                <div class="form-floating mb-3" id="emailContainer">
                    <input type="email" id="emailInput" name="email" class="form-control border-0 shadow-sm" placeholder="name@example.com" style="background-color: var(--bg-light);" />
                    <label for="emailInput"><i class="bi bi-envelope text-primary me-2"></i>Email Address</label>
                </div>

                <!-- Password Input -->
                <div class="form-floating mb-4">
                    <input type="password" id="passwordInput" name="password" class="form-control border-0 shadow-sm" required placeholder="Password" style="background-color: var(--bg-light);" />
                    <label for="passwordInput"><i class="bi bi-lock text-primary me-2"></i>Password</label>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input shadow-sm" id="rememberMe">
                        <label class="form-check-label small text-muted text-nowrap" for="rememberMe">Remember me</label>
                    </div>
                    <a href="#" class="small text-primary text-decoration-none fw-medium ms-2">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-3 mb-4">
                    Sign In <i class="bi bi-arrow-right ms-2 align-middle"></i>
                </button>
            </form>
            
            <div class="text-center position-relative mb-4">
                <hr class="text-muted opacity-25">
                <span class="bg-white px-3 text-muted small position-absolute top-50 start-50 translate-middle">New to SmartInsurance?</span>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2">
                <a href="/Auth/RegisterCustomer" class="btn btn-outline-smart flex-grow-1 py-2 fs-6">
                    <i class="bi bi-person me-2"></i> Register Customer
                </a>
                <a href="/Auth/RegisterAgent" class="btn btn-outline-smart flex-grow-1 py-2 fs-6">
                    <i class="bi bi-briefcase me-2"></i> Register Agent
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.getElementById('roleSelect');
            const companyContainer = document.getElementById('companyContainer');
            const companyDropdown = document.getElementById('companyDropdown');
            const emailContainer = document.getElementById('emailContainer');
            const emailInput = document.getElementById('emailInput');

            function toggleFields() {
                if (roleSelect.value === 'Company') {
                    companyContainer.classList.remove('d-none');
                    emailContainer.classList.add('d-none');
                    companyDropdown.required = true;
                    emailInput.required = false;
                    emailInput.value = ''; 
                } else {
                    companyContainer.classList.add('d-none');
                    emailContainer.classList.remove('d-none');
                    companyDropdown.required = false;
                    emailInput.required = true;
                    companyDropdown.value = ''; 
                }
            }

            roleSelect.addEventListener('change', toggleFields);
            toggleFields();
        });
    </script>
</body>
</html>
