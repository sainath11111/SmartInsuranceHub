@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-split-wrapper">
    <!-- Left Side: Graphic / Branding -->
    <div class="auth-split-left">
        <div class="mb-auto">
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="40" class="me-2 rounded shadow-sm">
                <span class="fs-4 fw-bold text-dark">Smart<span class="text-primary">Insurance</span></span>
            </a>
        </div>
        <div class="z-3">
            <h1 class="display-4 fw-bold text-secondary mb-4">Create a <span class="text-primary">new password</span></h1>
            <p class="fs-5 text-muted mb-4">Choose a strong, unique password to protect your account. Make it at least 6 characters long.</p>
        </div>
        <div class="mt-auto">
            <div class="d-flex align-items-center bg-white p-3 rounded-4 shadow-sm" style="max-width: 300px;">
                <div class="bg-success-subtle text-success p-2 rounded-circle me-3">
                    <i class="bi bi-check-circle fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">Account Verified</h6>
                    <small class="text-muted">You can now set a new password.</small>
                </div>
            </div>
        </div>

        <!-- Decorative Shapes -->
        <div class="position-absolute rounded-circle" style="width: 500px; height: 500px; background: rgba(16,185,129,0.05); top: -100px; right: -100px; z-index: 1;"></div>
        <div class="position-absolute rounded-circle" style="width: 300px; height: 300px; background: rgba(37,99,235,0.05); bottom: -50px; left: -50px; z-index: 1;"></div>
    </div>

    <!-- Right Side: Form -->
    <div class="auth-split-right">
        <div class="auth-card-inner">
            <div class="text-center mb-5 d-lg-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="48" class="rounded shadow-sm mb-3">
                <h2 class="fw-bold">Set New Password</h2>
            </div>

            <h2 class="fw-bold text-dark mb-1 d-none d-lg-block">Set New Password</h2>
            <p class="text-muted mb-4 d-none d-lg-block">Enter a new password for your account.</p>

            <!-- Account Info Badge -->
            <div class="d-flex align-items-center bg-primary bg-opacity-10 rounded-3 p-3 mb-4">
                <i class="bi bi-person-check-fill text-primary fs-4 me-3"></i>
                <div>
                    <small class="text-muted d-block">Resetting password for</small>
                    <strong class="text-dark">@ViewBag.Email</strong>
                    <span class="badge bg-primary ms-2">@ViewBag.Role</span>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center border-0 rounded-3 mb-4 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-3"></i>
                    <div>@ViewBag.Error</div>
                </div>
            }

            <form method="post" action="/Auth/ResetPassword">
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <!-- New Password -->
                <div class="form-floating mb-3">
                    <input type="password" id="newPassword" name="newPassword" class="form-control border-0 shadow-sm"
                           required placeholder="New Password" minlength="6"
                           style="background-color: var(--bg-light);" />
                    <label for="newPassword"><i class="bi bi-lock text-primary me-2"></i>New Password</label>
                </div>

                <!-- Confirm Password -->
                <div class="form-floating mb-4">
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control border-0 shadow-sm"
                           required placeholder="Confirm Password" minlength="6"
                           style="background-color: var(--bg-light);" />
                    <label for="confirmPassword"><i class="bi bi-lock-fill text-primary me-2"></i>Confirm Password</label>
                </div>

                <!-- Password strength indicator -->
                <div class="mb-4">
                    <div class="d-flex gap-1 mb-1" id="strengthBars">
                        <div class="flex-grow-1 rounded-pill" style="height: 4px; background: #e2e8f0;" id="bar1"></div>
                        <div class="flex-grow-1 rounded-pill" style="height: 4px; background: #e2e8f0;" id="bar2"></div>
                        <div class="flex-grow-1 rounded-pill" style="height: 4px; background: #e2e8f0;" id="bar3"></div>
                        <div class="flex-grow-1 rounded-pill" style="height: 4px; background: #e2e8f0;" id="bar4"></div>
                    </div>
                    <small class="text-muted" id="strengthText">Enter a password</small>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-3 mb-4">
                    <i class="bi bi-check-circle me-2"></i>Reset Password
                </button>
            </form>

            <div class="text-center">
                <a href="/Auth/Login" class="text-primary text-decoration-none fw-medium">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const pwd = document.getElementById('newPassword');
            const confirm = document.getElementById('confirmPassword');
            const bars = [document.getElementById('bar1'), document.getElementById('bar2'), document.getElementById('bar3'), document.getElementById('bar4')];
            const text = document.getElementById('strengthText');

            pwd.addEventListener('input', function () {
                const val = pwd.value;
                let score = 0;
                if (val.length >= 6) score++;
                if (val.length >= 8) score++;
                if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
                if (/[0-9]/.test(val) || /[^a-zA-Z0-9]/.test(val)) score++;

                const colors = ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
                const labels = ['Weak', 'Fair', 'Good', 'Strong'];

                bars.forEach((bar, i) => {
                    bar.style.background = i < score ? colors[score - 1] : '#e2e8f0';
                });
                text.textContent = score > 0 ? labels[score - 1] : 'Enter a password';
                text.style.color = score > 0 ? colors[score - 1] : '#94a3b8';
            });
        });
    </script>
</body>
</html>
