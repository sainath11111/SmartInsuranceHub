@model SmartInsuranceHub.Models.Agent
@{
    ViewData["Title"] = "Agent Registration";
    Layout = "_AuthLayout";
}
<div class="auth-card card">
    <div class="auth-header bg-info text-white">
        <h3 class="mb-0">Agent Registration</h3>
    </div>
    <div class="card-body p-4">
        <form method="post" action="/Auth/RegisterAgent">
            <div class="mb-3">
                <label class="form-label">Select Company</label>
                <select name="company_id" class="form-select" required>
                    <option value="">-- Select Insurance Company --</option>
                    @if(ViewBag.Companies != null)
                    {
                        foreach(var company in ViewBag.Companies)
                        {
                            <option value="@company.company_id">@company.company_name</option>
                        }
                    }
                </select>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" asp-for="full_name" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" asp-for="email" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" asp-for="password" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" asp-for="phone" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Experience (Years)</label>
                    <input type="number" asp-for="experience_years" class="form-control" required />
                </div>
                <div class="col-md-12 mb-3">
                    <label class="form-label">License Number</label>
                    <input type="text" asp-for="license_number" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">City</label>
                    <input type="text" asp-for="city" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Pincode</label>
                    <input type="text" asp-for="pincode" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Profile Photo URL</label>
                    <input type="text" asp-for="profile_photo" class="form-control" required />
                </div>
                <div class="col-md-12 mb-4">
                    <label class="form-label">Address</label>
                    <input type="text" asp-for="address" class="form-control" required />
                </div>
            </div>
            <button type="submit" class="btn btn-info text-white w-100 py-2 fw-semibold">Register Agent</button>
            <div class="text-center mt-3">
                <a href="/Auth/Login" class="text-decoration-none">Back to Login</a>
            </div>
        </form>
    </div>
</div>
