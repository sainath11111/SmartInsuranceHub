@model SmartInsuranceHub.Models.Agent
@{
    ViewData["Title"] = "Agent Registration";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-split-wrapper">
    <!-- Left Side: Graphic / Branding -->
    <div class="auth-split-left" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--primary-dark) 100%);">
        <div class="mb-auto position-relative z-3">
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="40" class="me-2 rounded bg-white p-1">
                <span class="fs-4 fw-bold text-white">Smart<span style="color: var(--primary-light);">Insurance</span></span>
            </a>
            <a href="/" class="btn btn-outline-light btn-sm mt-3 rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Home</a>
        </div>
        <div class="z-3">
            <h1 class="display-4 fw-bold text-white mb-4">Partner with <br><span style="color: var(--primary-light);">Industry Leaders</span>.</h1>
            <p class="fs-5 text-white-50 mb-4">Grow your career, access premium leads, and manage your portfolio with our cutting-edge agent dashboard.</p>
        </div>
        <div class="mt-auto z-3">
            <div class="d-flex align-items-center bg-white p-3 rounded-4 shadow-sm" style="max-width: 320px; background: rgba(255,255,255,0.1) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2);">
                <div class="bg-white text-primary p-2 rounded-circle me-3">
                    <i class="bi bi-graph-up-arrow fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white">Boost Commissions</h6>
                    <small class="text-white-50">Earn more securely.</small>
                </div>
            </div>
        </div>
        <div class="position-absolute rounded-circle" style="width: 700px; height: 700px; border: 2px solid rgba(255,255,255,0.05); top: -200px; right: -200px; z-index: 1;"></div>
    </div>

    <!-- Right Side: Form (Scrollable) -->
    <div class="auth-split-right" style="overflow-y: auto; align-items: flex-start; padding-top: 4rem; padding-bottom: 4rem;">
        <div class="auth-card-inner mx-auto" style="max-width: 550px;">
            <div class="text-center mb-5 d-lg-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="48" class="rounded shadow-sm mb-3">
                <h2 class="fw-bold">Become an Agent</h2>
            </div>
            
            <h2 class="card-title fw-bold text-center mb-1">Agent Application</h2>
            <p class="text-muted text-center mb-4">Join our network of premium insurance professionals</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm rounded-3">
                    <div asp-validation-summary="All" class="text-danger mb-0 small fw-bold"></div>
                </div>
            }

            <form asp-action="RegisterAgent" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
                <div class="row g-3">
                    
                    <!-- Profile Photo Upload -->
                    <div class="col-12 text-center mb-2">
                        <div class="position-relative d-inline-block">
                            <img id="profilePreview" src="~/images/default-avatar.png" alt="Profile Preview" class="rounded-circle shadow-sm border border-3 border-white bg-light" style="width: 120px; height: 120px; object-fit: cover; cursor: pointer;" onclick="document.getElementById('profilePhotoInput').click()" onerror="this.src='https://ui-avatars.com/api/?name=Agent&background=random'" />
                            <label for="profilePhotoInput" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 shadow-sm" style="cursor: pointer; transform: translate(10%, 10%);">
                                <i class="bi bi-camera"></i>
                            </label>
                        </div>
                        <input type="file" id="profilePhotoInput" name="profilePhotoFile" accept=".jpg,.jpeg,.png" class="d-none" onchange="previewProfileImage(event)" />
                        <div class="small text-muted mt-2">Upload Profile Photo (optional, max 2MB)</div>
                        <span class="text-danger small" asp-validation-for="profile_photo"></span>
                    </div>
                    <!-- Select Company -->
                    <div class="col-12">
                        <div class="form-floating mb-2">
                            <select name="company_id" class="form-select border-0 shadow-sm" required style="background-color: var(--bg-light);">
                                <option value="">-- Select Insurance Provider --</option>
                                @if(ViewBag.Companies != null)
                                {
                                    foreach(var company in ViewBag.Companies)
                                    {
                                        <option value="@company.company_id">@company.company_name</option>
                                    }
                                }
                            </select>
                            <label><i class="bi bi-building text-primary me-2"></i>Host Agency / Company</label>
                        </div>
                    </div>

                    <!-- Full Name -->
                    <div class="col-md-12">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="full_name" class="form-control border-0 shadow-sm" required placeholder="Full Name" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-person-badge text-primary me-2"></i>Full Name</label>
                        </div>
                    </div>
                    
                    <!-- Email & Password -->
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="email" asp-for="email" class="form-control border-0 shadow-sm" required placeholder="Email Address" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-envelope text-primary me-2"></i>Email Address</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="password" asp-for="password" class="form-control border-0 shadow-sm" required placeholder="Password" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-lock text-primary me-2"></i>Password</label>
                        </div>
                    </div>
                    
                    <!-- Phone & DOB -->
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="phone" class="form-control border-0 shadow-sm" required placeholder="Phone Number" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-telephone text-primary me-2"></i>Phone Number</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="date" asp-for="dob" class="form-control border-0 shadow-sm" required style="background-color: var(--bg-light);" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <label><i class="bi bi-calendar text-primary me-2"></i>Date of Birth</label>
                        </div>
                    </div>
                    
                    <!-- Identity Documents -->
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="aadhaar" class="form-control border-0 shadow-sm" required placeholder="Aadhaar Card" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-person-badge text-primary me-2"></i>Aadhaar Card</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="pan" class="form-control border-0 shadow-sm" required placeholder="PAN Card" style="text-transform: uppercase; background-color: var(--bg-light);" />
                            <label><i class="bi bi-card-text text-primary me-2"></i>PAN Card</label>
                        </div>
                    </div>
                    
                    <!-- Experience & License -->
                    <div class="col-md-4">
                        <div class="form-floating mb-2">
                            <input type="number" asp-for="experience_years" class="form-control border-0 shadow-sm" required placeholder="Experience" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-star-fill text-primary me-2"></i>Experience (Yrs)</label>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="license_number" class="form-control border-0 shadow-sm" required placeholder="License Number" style="text-transform: uppercase; background-color: var(--bg-light);" />
                            <label><i class="bi bi-award text-primary me-2"></i>Agent License Number</label>
                        </div>
                    </div>
                    
                    <!-- Location Details -->
                    <div class="col-md-6">
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted ps-1"><i class="bi bi-geo-alt text-primary me-2"></i>Select Service Cities</label>
                            <select name="SelectedCities" class="form-select border-0 shadow-sm" multiple required style="background-color: var(--bg-light); height: 120px;">
                                @{
                                    var cities = ViewBag.Cities as List<SmartInsuranceHub.Models.City>;
                                }
                                @if (cities != null && cities.Any())
                                {
                                    @foreach (var c in cities)
                                    {
                                        <option value="@c.city_name">@c.city_name@(c.state != null ? $" ({c.state})" : "")</option>
                                    }
                                }
                                else
                                {
                                    <option disabled>No cities configured yet</option>
                                }
                            </select>
                            <div class="small text-muted mt-1" style="font-size: 0.70rem;">Hold Ctrl (Windows) or Cmd (Mac) to select multiple</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="pincode" class="form-control border-0 shadow-sm" required placeholder="Pincode" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-pin-map text-primary me-2"></i>ZIP/Pincode</label>
                        </div>
                    </div>
                    
                    <!-- Address -->
                    <div class="col-md-12">
                        <div class="form-floating mb-2">
                            <input type="text" asp-for="address" class="form-control border-0 shadow-sm" required placeholder="Full Address" style="background-color: var(--bg-light);" />
                            <label><i class="bi bi-house text-primary me-2"></i>Office/Home Address</label>
                        </div>
                    </div>
                </div>

                <div class="form-check mt-4 mb-4">
                    <input type="checkbox" class="form-check-input shadow-sm" id="terms" required>
                    <label class="form-check-label small text-muted" for="terms">I agree to the <a href="/Home/Terms" target="_blank" class="text-primary text-decoration-none fw-medium">Terms of Service</a> and <a href="/Home/Privacy" target="_blank" class="text-primary text-decoration-none fw-medium">Privacy Policy</a>.</label>
                </div>

                <div class="mt-2 text-center">
                    <button type="submit" class="btn fw-bold w-100 py-3 mb-4 shadow-md text-white border-0" style="background: var(--secondary); transition: all 0.3s;" onmouseover="this.style.background='var(--primary)'" onmouseout="this.style.background='var(--secondary)'">
                        Submit Application <i class="bi bi-send-check ms-2"></i>
                    </button>
                    <p class="text-muted small mb-0">Already an agent? <a href="/Auth/Login" class="text-primary fw-bold text-decoration-none ms-1">Sign in</a></p>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function previewProfileImage(event) {
            const input = event.target;
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('profilePreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>
