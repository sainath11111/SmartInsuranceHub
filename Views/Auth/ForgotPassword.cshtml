@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-split-wrapper">
    <!-- Left Side: Graphic / Branding -->
    <div class="auth-split-left">
        <div class="mb-auto">
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="40" class="me-2 rounded shadow-sm">
                <span class="fs-4 fw-bold text-dark">Smart<span class="text-primary">Insurance</span></span>
            </a>
            <a href="/" class="btn btn-outline-primary btn-sm mt-3 rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Home</a>
        </div>
        <div class="z-3">
            <h1 class="display-4 fw-bold text-secondary mb-4">Forgot your <span class="text-primary">password?</span></h1>
            <p class="fs-5 text-muted mb-4">No worries! Enter your registered email or company name and we'll help you reset your password securely.</p>
        </div>
        <div class="mt-auto">
            <div class="d-flex align-items-center bg-white p-3 rounded-4 shadow-sm" style="max-width: 300px;">
                <div class="bg-warning-subtle text-warning p-2 rounded-circle me-3">
                    <i class="bi bi-key fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">Secure Reset</h6>
                    <small class="text-muted">Your password is encrypted.</small>
                </div>
            </div>
        </div>

        <!-- Decorative Shapes -->
        <div class="position-absolute rounded-circle" style="width: 500px; height: 500px; background: rgba(245,158,11,0.05); top: -100px; right: -100px; z-index: 1;"></div>
        <div class="position-absolute rounded-circle" style="width: 300px; height: 300px; background: rgba(37,99,235,0.05); bottom: -50px; left: -50px; z-index: 1;"></div>
    </div>

    <!-- Right Side: Form -->
    <div class="auth-split-right">
        <div class="auth-card-inner">
            <div class="text-center mb-5 d-lg-none">
                <img src="~/images/logo.png" alt="SmartInsurance" height="48" class="rounded shadow-sm mb-3">
                <h2 class="fw-bold">Reset Password</h2>
            </div>

            <h2 class="fw-bold text-dark mb-1 d-none d-lg-block">Reset Password</h2>
            <p class="text-muted mb-4 d-none d-lg-block">Enter your details to verify your account.</p>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center border-0 rounded-3 mb-4 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-3"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center border-0 rounded-3 mb-4 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-octagon-fill fs-5 me-3"></i>
                    <div>@ViewBag.Error</div>
                </div>
            }

            <form method="post" action="/Auth/ForgotPassword">
                <!-- Role Selector -->
                <div class="form-floating mb-3">
                    <select name="role" id="roleSelect" class="form-select border-0 shadow-sm" style="background-color: var(--bg-light);">
                        <option value="Customer" selected="@(ViewBag.SelectedRole == "Customer" ? "selected" : null)">Customer</option>
                        <option value="Agent" selected="@(ViewBag.SelectedRole == "Agent" ? "selected" : null)">Agent</option>
                        <option value="Company" selected="@(ViewBag.SelectedRole == "Company" ? "selected" : null)">Insurance Company</option>
                    </select>
                    <label for="roleSelect"><i class="bi bi-person-badge text-primary me-2"></i>Account Type</label>
                </div>

                <!-- Email Input (for Customer / Agent) -->
                <div class="form-floating mb-3" id="emailContainer">
                    <input type="email" id="emailInput" name="email" class="form-control border-0 shadow-sm"
                           placeholder="name@example.com" value="@(ViewBag.EnteredEmail ?? "")"
                           style="background-color: var(--bg-light);" />
                    <label for="emailInput"><i class="bi bi-envelope text-primary me-2"></i>Registered Email Address</label>
                </div>

                <!-- Company Name Input (for Company) -->
                <div class="form-floating mb-3 d-none" id="companyNameContainer">
                    <input type="text" id="companyNameInput" name="companyName" class="form-control border-0 shadow-sm"
                           placeholder="Company Name" value="@(ViewBag.EnteredCompanyName ?? "")"
                           style="background-color: var(--bg-light);" />
                    <label for="companyNameInput"><i class="bi bi-building text-primary me-2"></i>Company Name</label>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-3 mb-4">
                    <i class="bi bi-arrow-right-circle me-2"></i>Verify & Continue
                </button>
            </form>

            <div class="text-center">
                <a href="/Auth/Login" class="text-primary text-decoration-none fw-medium">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleSelect = document.getElementById('roleSelect');
            const emailContainer = document.getElementById('emailContainer');
            const emailInput = document.getElementById('emailInput');
            const companyNameContainer = document.getElementById('companyNameContainer');
            const companyNameInput = document.getElementById('companyNameInput');

            function toggleFields() {
                if (roleSelect.value === 'Company') {
                    emailContainer.classList.add('d-none');
                    companyNameContainer.classList.remove('d-none');
                    emailInput.required = false;
                    companyNameInput.required = true;
                } else {
                    emailContainer.classList.remove('d-none');
                    companyNameContainer.classList.add('d-none');
                    emailInput.required = true;
                    companyNameInput.required = false;
                }
            }

            roleSelect.addEventListener('change', toggleFields);
            toggleFields();
        });
    </script>
</body>
</html>
