@model SmartInsuranceHub.Models.Customer
@{
    ViewData["Title"] = "Customer Registration";
    Layout = "_AuthLayout";
}
<div class="auth-card card">
    <div class="auth-header bg-primary">
        <h3 class="mb-0">Customer Registration</h3>
    </div>
    <div class="card-body p-4">
        <form method="post" action="/Auth/RegisterCustomer">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" asp-for="full_name" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" asp-for="email" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" asp-for="password" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" asp-for="phone" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Age</label>
                    <input type="number" asp-for="age" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">City</label>
                    <input type="text" asp-for="city" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Address</label>
                    <input type="text" asp-for="address" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">PAN Card</label>
                    <input type="text" asp-for="c_pancard" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Adhar Card</label>
                    <input type="text" asp-for="c_adhar" class="form-control" required />
                </div>
                <div class="col-md-12 mb-4">
                    <label class="form-label">Family Information</label>
                    <textarea asp-for="family_info" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Register Customer</button>
            <div class="text-center mt-3">
                <a href="/Auth/Login" class="text-decoration-none">Back to Login</a>
            </div>
        </form>
    </div>
</div>
