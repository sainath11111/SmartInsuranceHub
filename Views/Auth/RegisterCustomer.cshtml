@model SmartInsuranceHub.Models.Customer
@{
    ViewData["Title"] = "Customer Registration";
    Layout = "_LandingLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary border-0 text-center py-4">
                    <h3 class="fw-bold text-white mb-0"><i class="bi bi-person-plus-fill me-2"></i>Customer Registration</h3>
                    <p class="text-white-50 mb-0 mt-1">Join Smart Insurance Hub today</p>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <form method="post" action="/Auth/RegisterCustomer">
                        <div class="row g-4">
                            <!-- Full Name -->
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input type="text" asp-for="full_name" class="form-control rounded-3" required placeholder="Full Name" />
                                    <label><i class="bi bi-person text-primary me-2"></i>Full Name</label>
                                </div>
                            </div>
                            
                            <!-- Email -->
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="email" asp-for="email" class="form-control rounded-3" required placeholder="Email Address" />
                                    <label><i class="bi bi-envelope text-primary me-2"></i>Email Address</label>
                                </div>
                            </div>
                            
                            <!-- Password -->
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="password" asp-for="password" class="form-control rounded-3" required placeholder="Password" />
                                    <label><i class="bi bi-lock text-primary me-2"></i>Password</label>
                                </div>
                            </div>
                            
                            <!-- Phone & Age -->
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" asp-for="phone" class="form-control rounded-3" required placeholder="Phone Number" />
                                    <label><i class="bi bi-telephone text-primary me-2"></i>Phone Number</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="number" asp-for="age" class="form-control rounded-3" required placeholder="Age" />
                                    <label><i class="bi bi-calendar text-primary me-2"></i>Age</label>
                                </div>
                            </div>
                            
                            <!-- City & Address -->
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" asp-for="city" class="form-control rounded-3" required placeholder="City" />
                                    <label><i class="bi bi-geo-alt text-primary me-2"></i>City</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" asp-for="address" class="form-control rounded-3" required placeholder="Full Address" />
                                    <label><i class="bi bi-house text-primary me-2"></i>Full Address</label>
                                </div>
                            </div>
                            
                            <!-- Docs -->
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" asp-for="c_pancard" class="form-control rounded-3" required placeholder="PAN Card" />
                                    <label><i class="bi bi-card-text text-primary me-2"></i>PAN Card</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" asp-for="c_adhar" class="form-control rounded-3" required placeholder="Aadhar Card" />
                                    <label><i class="bi bi-card-heading text-primary me-2"></i>Adhar Card</label>
                                </div>
                            </div>
                            
                            <!-- Family Info -->
                            <div class="col-md-12">
                                <div class="form-floating border rounded-3 p-1">
                                    <textarea asp-for="family_info" class="form-control border-0 shadow-none" placeholder="Family Information" style="height: 80px"></textarea>
                                    <label class="ps-3"><i class="bi bi-people text-primary me-2"></i>Family Information (Optional)</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-5">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm" style="letter-spacing: 0.5px;">
                                Create Customer Account <i class="bi bi-arrow-right-circle ms-2"></i>
                            </button>
                        </div>
                        
                        <div class="text-center mt-4 pt-3 border-top">
                            <p class="text-muted small mb-0">Already have an account? <a href="/Auth/Login" class="text-primary fw-semibold text-decoration-none">Sign in here</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
