@{
    ViewData["Title"] = "My Profile";
    var userType = (string)ViewBag.UserType;
    var documents = (List<SmartInsuranceHub.Models.UserDocument>)ViewBag.Documents;
    var requiredDocs = (List<(string Category, List<string> Documents)>)ViewBag.RequiredDocs;
    var completed = (int)ViewBag.Completed;
    var total = (int)ViewBag.Total;
    var percentage = (int)ViewBag.Percentage;
    var verificationStatus = (string)ViewBag.VerificationStatus;
}

<style>
    .profile-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        border-radius: 16px;
        padding: 2.5rem;
        color: white;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .profile-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
        border-radius: 50%;
    }
    .profile-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: white;
        border: 3px solid rgba(255,255,255,0.2);
    }
    .badge-verified {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .badge-unverified {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .tab-nav { border-bottom: 2px solid #e2e8f0; margin-bottom: 1.5rem; }
    .tab-nav .nav-link {
        color: #64748b;
        font-weight: 600;
        border: none;
        padding: 10px 20px;
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
    }
    .tab-nav .nav-link.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
        background: transparent;
    }
    .progress-card {
        background: linear-gradient(135deg, #1e293b, #334155);
        border-radius: 14px;
        padding: 1.5rem;
        color: white;
        margin-bottom: 1.5rem;
    }
    .progress-bar-custom {
        height: 10px;
        border-radius: 5px;
        background: #475569;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        border-radius: 5px;
        background: linear-gradient(90deg, #6366f1, #8b5cf6);
        transition: width 0.6s ease;
    }
    .doc-category-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        margin-bottom: 1rem;
        overflow: hidden;
        transition: box-shadow 0.2s;
    }
    .doc-category-card:hover { box-shadow: 0 4px 15px rgba(0,0,0,0.08); }
    .doc-category-header {
        background: #f8fafc;
        padding: 14px 18px;
        font-weight: 600;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid #e2e8f0;
    }
    .doc-item {
        padding: 12px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #f1f5f9;
    }
    .doc-item:last-child { border-bottom: none; }
    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .status-not-uploaded { background: #f1f5f9; color: #64748b; }
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-approved { background: #d1fae5; color: #065f46; }
    .status-rejected { background: #fee2e2; color: #991b1b; }
    .upload-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s;
    }
    .upload-btn:hover { transform: scale(1.03); color: white; }
    .delete-btn {
        background: none;
        border: 1px solid #ef4444;
        color: #ef4444;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.15s;
    }
    .delete-btn:hover { background: #ef4444; color: white; }
</style>

<!-- Profile Hero -->
<div class="profile-hero">
    <div class="d-flex align-items-center gap-3">
        <div class="profile-avatar">
            @(((string)ViewBag.UserName)?.Substring(0, 1).ToUpper())
        </div>
        <div>
            <h4 class="mb-1">@ViewBag.UserName</h4>
            <p class="mb-1 text-white-50">@ViewBag.UserEmail</p>
            <span class="@(verificationStatus == "verified" ? "badge-verified" : "badge-unverified")">
                <i class="bi @(verificationStatus == "verified" ? "bi-patch-check-fill" : "bi-clock") me-1"></i>
                @(verificationStatus == "verified" ? "Verified" : "Unverified")
            </span>
        </div>
    </div>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null) {
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null) {
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Tabs -->
<ul class="nav tab-nav" id="profileTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button">
            <i class="bi bi-person me-1"></i> Profile Info
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link active" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button">
            <i class="bi bi-file-earmark-text me-1"></i> Documents
        </button>
    </li>
</ul>

<div class="tab-content" id="profileTabContent">
    <!-- Profile Info Tab -->
    <div class="tab-pane fade" id="info" role="tabpanel">
        <div class="card border-0 shadow-sm" style="border-radius:14px;">
            <div class="card-body p-4">
                <h5 class="mb-4"><i class="bi bi-info-circle me-2"></i>Personal Information</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Full Name</label>
                        <p class="fw-semibold">@ViewBag.UserName</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Email</label>
                        <p class="fw-semibold">@ViewBag.UserEmail</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Phone</label>
                        <p class="fw-semibold">@(ViewBag.UserPhone ?? "Not provided")</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Role</label>
                        <p class="fw-semibold">@userType</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Documents Tab -->
    <div class="tab-pane fade show active" id="docs" role="tabpanel">

        <!-- Progress Card -->
        <div class="progress-card">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <h6 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Document Completion</h6>
                    <small class="text-white-50">@completed / @total categories verified</small>
                </div>
                <span class="fs-4 fw-bold">@(percentage)%</span>
            </div>
            <div class="progress-bar-custom">
                <div class="progress-bar-fill" style="width: @(percentage)%"></div>
            </div>
        </div>

        <!-- Document Categories -->
        @foreach (var cat in requiredDocs)
        {
            var categoryDocs = documents.Where(d => d.category == cat.Category).ToList();
            var categoryApproved = categoryDocs.Any(d => d.status == "approved");
            var categoryIcon = cat.Category switch {
                "Identity Proof" => "bi-person-badge",
                "Address Proof" => "bi-geo-alt",
                "Age Proof" => "bi-calendar",
                "Income Proof" => "bi-cash-coin",
                "Photograph" => "bi-camera",
                "Bank Details" => "bi-bank",
                "Medical Documents" => "bi-heart-pulse",
                "Professional License" => "bi-award",
                "Education" => "bi-book",
                "Company Authorization" => "bi-briefcase",
                _ => "bi-file-earmark"
            };

            <div class="doc-category-card">
                <div class="doc-category-header">
                    <i class="bi @categoryIcon"></i>
                    @cat.Category
                    @if (categoryApproved) {
                        <span class="status-badge status-approved ms-auto"><i class="bi bi-check-circle me-1"></i>Verified</span>
                    }
                </div>

                @foreach (var docName in cat.Documents)
                {
                    var uploadedDoc = categoryDocs.FirstOrDefault(d => d.document_name == docName);
                    var docStatus = uploadedDoc?.status ?? "not_uploaded";

                    <div class="doc-item">
                        <div>
                            <span class="fw-semibold">@docName</span>
                            @if (uploadedDoc != null)
                            {
                                <br><small class="text-muted">@uploadedDoc.file_name · @((uploadedDoc.file_size / 1024.0).ToString("F0")) KB</small>
                            }
                            @if (docStatus == "rejected" && !string.IsNullOrEmpty(uploadedDoc?.rejection_reason))
                            {
                                <br><small class="text-danger"><i class="bi bi-exclamation-circle"></i> @uploadedDoc.rejection_reason</small>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="status-badge status-@docStatus">
                                @(docStatus switch {
                                    "pending" => "Under Review",
                                    "approved" => "Approved",
                                    "rejected" => "Rejected",
                                    _ => "Not Uploaded"
                                })
                            </span>

                            @if (uploadedDoc != null && (docStatus == "pending" || docStatus == "approved"))
                            {
                                <a href="/Document/Preview/@uploadedDoc.document_id" target="_blank" class="btn btn-sm btn-outline-primary" title="Preview">
                                    <i class="bi bi-eye"></i>
                                </a>
                            }

                            @if (docStatus == "not_uploaded" || docStatus == "rejected")
                            {
                                <!-- Upload form -->
                                <form method="post" action="/Document/Upload" enctype="multipart/form-data" class="d-inline upload-form">
                                    <input type="hidden" name="category" value="@cat.Category" />
                                    <input type="hidden" name="documentName" value="@docName" />
                                    <label class="upload-btn mb-0">
                                        <i class="bi bi-cloud-upload me-1"></i>Upload
                                        <input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png" style="display:none;" onchange="this.form.submit();" />
                                    </label>
                                </form>
                            }

                            @if (uploadedDoc != null && docStatus != "approved")
                            {
                                <form method="post" action="/Document/DeleteDocument" class="d-inline">
                                    <input type="hidden" name="id" value="@uploadedDoc.document_id" />
                                    <button type="submit" class="delete-btn" onclick="return confirm('Remove this document?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
