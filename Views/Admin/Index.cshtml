@{
    ViewData["Title"] = "System Overview";
}

<style>
    .adm-kpi {
        background: #ffffff; border-radius: 18px; border: 1px solid rgba(226,232,240,0.8);
        padding: 1.5rem; box-shadow: 0 4px 24px rgba(30,64,175,0.04);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        position: relative; overflow: hidden; height: 100%;
    }
    .adm-kpi::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 18px 18px 0 0;
    }
    .adm-kpi.blue::before   { background: linear-gradient(90deg,#2563eb,#60a5fa); }
    .adm-kpi.green::before  { background: linear-gradient(90deg,#10b981,#34d399); }
    .adm-kpi.slate::before  { background: linear-gradient(90deg,#475569,#94a3b8); }
    .adm-kpi.amber::before  { background: linear-gradient(90deg,#f59e0b,#fcd34d); }
    .adm-kpi.danger::before { background: linear-gradient(90deg,#ef4444,#fca5a5); }
    .adm-kpi:hover { transform: translateY(-5px); box-shadow: 0 12px 36px rgba(30,64,175,0.10); }
    .adm-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; }
    .adm-lbl { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; }
    .adm-val { font-size: 2rem; font-weight: 800; color: #0f172a; font-family: 'Outfit', sans-serif; line-height: 1.1; }

    .adm-action {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1rem 1.25rem; text-decoration: none; color: #0f172a;
        display: flex; align-items: center; gap: 0.875rem;
        transition: all 0.25s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .adm-action:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(37,99,235,.10); border-color: #93c5fd; color: #1d4ed8; }
    .adm-action-icon { width: 44px; height: 44px; border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .section-eyebrow { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; }
    .section-title { font-size: 1.15rem; font-weight: 800; font-family: 'Outfit', sans-serif; color: #0f172a; margin: 0; }
</style>

<!-- Page Heading -->
<div class="mb-4" data-aos="fade-down">
    <p class="section-eyebrow mb-1"><i class="bi bi-speedometer2 me-1"></i> Admin Control Centre</p>
    <h2 class="fw-bold mb-0" style="font-family:'Outfit',sans-serif; letter-spacing: -0.02em;">System Overview</h2>
    <p class="text-muted mb-0 mt-1">Platform health and operational metrics — @DateTime.Now.ToString("dddd, d MMMM yyyy")</p>
</div>

<!-- Primary KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3" data-aos="fade-up" data-aos-delay="50">
        <div class="adm-kpi blue">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="adm-icon" style="background:rgba(37,99,235,0.10); color:#2563eb;">
                    <i class="bi bi-buildings-fill"></i>
                </div>
                <span class="badge rounded-pill" style="background:rgba(16,185,129,0.1); color:#059669; font-size:0.7rem; font-weight:700;">+2 this week</span>
            </div>
            <p class="adm-lbl mb-1">Companies</p>
            <p class="adm-val">@ViewBag.TotalCompanies</p>
        </div>
    </div>
    <div class="col-6 col-xl-3" data-aos="fade-up" data-aos-delay="100">
        <div class="adm-kpi green">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="adm-icon" style="background:rgba(16,185,129,0.10); color:#10b981;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
            </div>
            <p class="adm-lbl mb-1">Active Agents</p>
            <p class="adm-val">@ViewBag.TotalAgents</p>
        </div>
    </div>
    <div class="col-6 col-xl-3" data-aos="fade-up" data-aos-delay="150">
        <div class="adm-kpi slate">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="adm-icon" style="background:rgba(71,85,105,0.10); color:#475569;">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <p class="adm-lbl mb-1">Customers</p>
            <p class="adm-val">@ViewBag.TotalCustomers</p>
        </div>
    </div>
    <div class="col-6 col-xl-3" data-aos="fade-up" data-aos-delay="200">
        <div class="adm-kpi amber">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="adm-icon" style="background:rgba(245,158,11,0.10); color:#f59e0b;">
                    <i class="bi bi-file-earmark-text-fill"></i>
                </div>
            </div>
            <p class="adm-lbl mb-1">Policies Sold</p>
            <p class="adm-val">@ViewBag.TotalPolicies</p>
        </div>
    </div>
</div>

<!-- Verification Queue Alert -->
@if ((int)ViewBag.PendingDocs > 0)
{
    <div class="d-flex align-items-start gap-3 p-3 rounded-3 mb-4"
         style="background:linear-gradient(135deg,#fffbeb,#fef3c7); border:1.5px solid #f59e0b;"
         data-aos="fade-up">
        <i class="bi bi-exclamation-triangle-fill fs-3 flex-shrink-0" style="color:#f59e0b; margin-top:2px;"></i>
        <div class="flex-grow-1">
            <strong class="text-dark d-block mb-1">Action Required — Document Review Queue</strong>
            <span class="text-muted" style="font-size:0.9rem;">
                <strong class="text-dark">@ViewBag.PendingDocs</strong> document(s) are awaiting review. Delays may affect customer onboarding.
            </span>
        </div>
        <a href="/Admin/DocumentVerification?filter=pending"
           class="btn btn-sm fw-bold px-4 rounded-pill flex-shrink-0"
           style="background:#f59e0b; color:#fff; white-space:nowrap;">
            Review Now
        </a>
    </div>
}

<!-- Verification Queue Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4" data-aos="fade-up" data-aos-delay="50">
        <div class="adm-kpi amber" style="cursor:default;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="adm-lbl mb-1">Pending Docs</p>
                    <p class="adm-val">@ViewBag.PendingDocs</p>
                </div>
                <div class="adm-icon" style="background:rgba(245,158,11,0.10); color:#f59e0b;">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
        <div class="adm-kpi green" style="cursor:default;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="adm-lbl mb-1">Verified Customers</p>
                    <p class="adm-val">@ViewBag.VerifiedCustomers</p>
                </div>
                <div class="adm-icon" style="background:rgba(16,185,129,0.10); color:#10b981;">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4" data-aos="fade-up" data-aos-delay="150">
        <div class="adm-kpi danger" style="cursor:default;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="adm-lbl mb-1">Rejected Docs</p>
                    <p class="adm-val">@ViewBag.RejectedDocs</p>
                </div>
                <div class="adm-icon" style="background:rgba(239,68,68,0.10); color:#ef4444;">
                    <i class="bi bi-x-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card-modern p-4" data-aos="fade-up">
    <p class="section-eyebrow mb-0"><i class="bi bi-grid-fill me-1 text-primary"></i>Management</p>
    <h5 class="section-title mb-4">Quick Actions</h5>
    <div class="row g-3">
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/Companies" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(37,99,235,0.10); color:#2563eb;"><i class="bi bi-building"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Companies</p>
                    <small class="text-muted">Manage</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/Agents" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(16,185,129,0.10); color:#10b981;"><i class="bi bi-person-badge"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Agents</p>
                    <small class="text-muted">Manage</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/Customers" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(71,85,105,0.10); color:#475569;"><i class="bi bi-people"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Customers</p>
                    <small class="text-muted">Manage</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/ManageAds" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(245,158,11,0.10); color:#f59e0b;"><i class="bi bi-megaphone-fill"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Advertisements</p>
                    <small class="text-muted">Review</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/DocumentVerification" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(124,58,237,0.10); color:#7c3aed;"><i class="bi bi-shield-check"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Doc Verify</p>
                    <small class="text-muted">Review queue</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/InsuranceTypes" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(14,165,233,0.10); color:#0ea5e9;"><i class="bi bi-tags-fill"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Categories</p>
                    <small class="text-muted">Plan types</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Query/Index" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(239,68,68,0.10); color:#ef4444;"><i class="bi bi-chat-left-text-fill"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Support</p>
                    <small class="text-muted">Queries</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Admin/Cities" class="adm-action">
                <div class="adm-action-icon" style="background:rgba(2,132,199,0.10); color:#0284c7;"><i class="bi bi-geo-alt-fill"></i></div>
                <div>
                    <p class="fw-bold mb-0" style="font-size:0.875rem;">Cities</p>
                    <small class="text-muted">Service areas</small>
                </div>
            </a>
        </div>
    </div>
</div>
