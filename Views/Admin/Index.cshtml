@{
    ViewData["Title"] = "System Overview";
}

<style>
    .metric-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
        padding: 1.5rem;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .metric-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.03);
        border-color: #cbd5e1;
    }
    .metric-icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    .metric-title {
        color: #64748b;
        font-weight: 500;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }
    .metric-value {
        color: #0f172a;
        font-size: 2rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0;
        font-family: 'Outfit', sans-serif;
    }
</style>

<div class="row g-4 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="metric-icon-box bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-buildings-fill"></i>
                </div>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill fw-medium">+2 this week</span>
            </div>
            <div class="mt-auto">
                <h6 class="metric-title">Total Companies</h6>
                <p class="metric-value">@ViewBag.TotalCompanies</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="metric-icon-box" style="background: #f0fdf4; color: #16a34a;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
            </div>
            <div class="mt-auto">
                <h6 class="metric-title">Active Agents</h6>
                <p class="metric-value">@ViewBag.TotalAgents</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="metric-icon-box" style="background: #f8fafc; color: #475569;">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="mt-auto">
                <h6 class="metric-title">Registered Customers</h6>
                <p class="metric-value">@ViewBag.TotalCustomers</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="metric-icon-box" style="background: #fefce8; color: #ca8a04;">
                    <i class="bi bi-file-earmark-text-fill"></i>
                </div>
            </div>
            <div class="mt-auto">
                <h6 class="metric-title">Total Policies Sold</h6>
                <p class="metric-value">@ViewBag.TotalPolicies</p>
            </div>
        </div>
    </div>
</div>

<h5 class="fw-bold text-dark mb-3 mt-4" style="font-family: 'Outfit', sans-serif;">Verification Queue</h5>

@if ((int)ViewBag.PendingDocs > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" style="border-radius:12px; border: 1px solid #fde68a; background: #fffbeb; color: #92400e;">
        <i class="bi bi-exclamation-circle-fill me-3 fs-4" style="color: #f59e0b;"></i>
        <div class="flex-grow-1">
            <strong class="d-block mb-1">Action Required</strong>
            <span>@ViewBag.PendingDocs document(s) awaiting your review. Delaying reviews may affect agent/customer onboarding.</span>
        </div>
        <a href="/Admin/DocumentVerification?filter=pending" class="btn btn-sm text-white px-3 py-2 fw-medium rounded-3" style="background: #d97706;">Review Documents</a>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
        <div class="metric-card" style="border-top: 4px solid #f59e0b;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="metric-title mb-1">Pending Docs</h6>
                    <p class="metric-value text-dark">@ViewBag.PendingDocs</p>
                </div>
                <div class="metric-icon-box" style="background: #fffbeb; color: #f59e0b;">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="metric-card" style="border-top: 4px solid #10b981;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="metric-title mb-1">Verified Customers</h6>
                    <p class="metric-value text-dark">@ViewBag.VerifiedCustomers</p>
                </div>
                <div class="metric-icon-box" style="background: #ecfdf5; color: #10b981;">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="metric-card" style="border-top: 4px solid #ef4444;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="metric-title mb-1">Rejected Docs</h6>
                    <p class="metric-value text-dark">@ViewBag.RejectedDocs</p>
                </div>
                <div class="metric-icon-box" style="background: #fef2f2; color: #ef4444;">
                    <i class="bi bi-x-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4" style="border-radius: 16px;">
    <div class="card-header bg-white border-bottom border-light pt-4 px-4 pb-3">
        <h5 class="mb-0 fw-bold" style="font-family: 'Outfit', sans-serif;">Quick Actions</h5>
    </div>
    <div class="card-body p-4 d-flex flex-wrap gap-3">
        <a href="/Admin/Companies" class="btn btn-light border shadow-sm rounded-3 py-2 px-4 d-flex align-items-center gap-2 fw-medium text-dark action-btn">
            <div class="bg-primary bg-opacity-10 text-primary rounded p-1"><i class="bi bi-building"></i></div> Manage Companies
        </a>
        <a href="/Admin/Agents" class="btn btn-light border shadow-sm rounded-3 py-2 px-4 d-flex align-items-center gap-2 fw-medium text-dark action-btn">
            <div class="bg-success bg-opacity-10 text-success rounded p-1"><i class="bi bi-person-badge"></i></div> Manage Agents
        </a>
        <a href="/Admin/ManageAds" class="btn btn-light border shadow-sm rounded-3 py-2 px-4 d-flex align-items-center gap-2 fw-medium text-dark action-btn">
            <div class="bg-warning bg-opacity-10 text-warning rounded p-1"><i class="bi bi-megaphone-fill"></i></div> Review Ads
        </a>
    </div>
</div>

<style>
    .action-btn { transition: all 0.2s; }
    .action-btn:hover { background: #f8fafc !important; transform: translateY(-2px); border-color: #cbd5e1 !important; }
</style>
