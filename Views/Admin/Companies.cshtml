@model IEnumerable<SmartInsuranceHub.Models.Company>
@{
    ViewData["Title"] = "Manage Companies";
}

<!-- Page Header with Seed Button -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-building me-2 text-primary"></i>Manage Companies</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#addCompanyForm">
            <i class="bi bi-plus-circle me-1"></i> Add Company
        </button>
        <form method="post" asp-action="SeedCompanies" onsubmit="return confirm('⚠️ This will DELETE all existing companies and replace them with 22 predefined Indian insurance companies. Are you sure?')">
            <button type="submit" class="btn btn-warning"><i class="bi bi-database-fill me-1"></i> Seed Default Companies</button>
        </form>
    </div>
</div>

<!-- Collapsible Add Company Form -->
<div class="collapse mb-4" id="addCompanyForm">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Add New Company</h5>
            <form method="post" asp-action="AddCompany">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Company Name <span class="text-danger">*</span></label>
                        <input type="text" name="company_name" class="form-control" placeholder="e.g. Star Health Insurance" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Email <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control" placeholder="e.g. starhealth@smartinsurance.com" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">License Number</label>
                        <input type="text" name="license_number" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Address</label>
                        <input type="text" name="address" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-medium">Description</label>
                        <input type="text" name="c_information" class="form-control" placeholder="Short description" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i> Add Company</button>
                    <small class="text-muted ms-3">Password will be auto-generated as <code>companyname@123</code></small>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Companies Table -->
<div class="card table-custom border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Company Name</th>
                    <th>Email</th>
                    <th>License</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="text-muted">@(idx++)</td>
                        <td class="fw-medium">@item.company_name</td>
                        <td class="small text-muted">@item.email</td>
                        <td>@(item.license_number ?? "—")</td>
                        <td>
                            @if(item.status == "pending") {
                                <span class="badge bg-warning text-dark">Pending</span>
                            } else if (item.status == "approved") {
                                <span class="badge bg-success">Approved</span>
                            } else {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>
                        <td class="text-center">
                            @if(item.status == "pending") {
                                <a href="/Admin/ApproveCompany/@item.company_id" class="btn btn-sm btn-outline-success me-1" title="Approve"><i class="bi bi-check-lg"></i></a>
                                <a href="/Admin/RejectCompany/@item.company_id" class="btn btn-sm btn-outline-warning me-1" title="Reject"><i class="bi bi-x-lg"></i></a>
                            }
                            <form method="post" asp-action="DeleteCompany" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this company?')">
                                <input type="hidden" name="id" value="@item.company_id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if(!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
                <p>No companies found. Click <strong>"Seed Default Companies"</strong> to populate the database.</p>
            </div>
        }
    </div>
</div>
<div class="text-muted small mt-3">Total: <strong>@Model.Count()</strong> companies</div>
