@model IEnumerable<SmartInsuranceHub.Models.Company>
@{
    ViewData["Title"] = "Manage Companies";
}

<div class="card table-custom">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Company Name</th>
                    <th>Email</th>
                    <th>License</th>
                    <th>Address</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td>@item.company_name</td>
                        <td>@item.email</td>
                        <td>@item.license_number</td>
                        <td>@item.address</td>
                        <td>
                            @if(item.status == "pending") {
                                <span class="badge bg-warning text-dark">Pending</span>
                            } else if (item.status == "approved") {
                                <span class="badge bg-success">Approved</span>
                            } else {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>
                        <td>
                            @if(item.status == "pending") {
                                <a href="/Admin/ApproveCompany/@item.company_id" class="btn btn-sm btn-success">Approve</a>
                                <a href="/Admin/RejectCompany/@item.company_id" class="btn btn-sm btn-danger">Reject</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
