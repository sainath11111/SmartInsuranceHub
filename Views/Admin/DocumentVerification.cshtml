@{
    ViewData["Title"] = "Document Verification";
    var documents = (List<SmartInsuranceHub.Models.UserDocument>)Model;
    var customerNames = (Dictionary<int, string>)ViewBag.CustomerNames;
    var agentNames = (Dictionary<int, string>)ViewBag.AgentNames;
    var activeFilter = (string)(ViewBag.Filter ?? "all");
    var search = (string)(ViewBag.Search ?? "");
}

<style>
    .verification-header { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-radius: 14px; padding: 2rem; color: white; margin-bottom: 2rem; }
    .stat-pill { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 20px; font-size: 0.85rem; color: white; }
    .filter-tabs { display: flex; gap: 8px; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .filter-tab { padding: 8px 20px; border-radius: 24px; font-size: 0.85rem; font-weight: 600; cursor: pointer; text-decoration: none; border: 2px solid transparent; transition: all 0.2s; }
    .filter-tab.active { background: #1e293b; color: white; border-color: #1e293b; }
    .filter-tab:not(.active) { background: white; color: #475569; border-color: #e2e8f0; }
    .filter-tab:not(.active):hover { border-color: #94a3b8; color: #1e293b; }
    .doc-table { border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; }
    .doc-table th { background: #f8fafc; color: #475569; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .doc-table td { vertical-align: middle; }
    .status-badge { padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .status-pending { background: #fef3c7; color: #92400e; }
    .status-approved { background: #d1fae5; color: #065f46; }
    .status-rejected { background: #fee2e2; color: #991b1b; }
    .action-btn { padding: 5px 14px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; border: none; cursor: pointer; transition: transform 0.1s; }
    .action-btn:hover { transform: scale(1.03); }
    .approve-btn { background: #10b981; color: white; }
    .reject-btn { background: #ef4444; color: white; }
    .user-link { color: #4f46e5; text-decoration: none; font-weight: 600; }
    .user-link:hover { text-decoration: underline; }
</style>

<div class="verification-header">
    <h4 class="mb-2"><i class="bi bi-shield-check me-2"></i>Document Verification</h4>
    <p class="text-white-50 mb-3">Review and approve user documents for KYC verification.</p>
    <div class="d-flex gap-3 flex-wrap">
        <span class="stat-pill"><i class="bi bi-list-ul"></i> @ViewBag.AllCount Total</span>
        <span class="stat-pill"><i class="bi bi-hourglass-split"></i> @ViewBag.PendingCount Pending</span>
        <span class="stat-pill"><i class="bi bi-check-circle"></i> @ViewBag.ApprovedCount Approved</span>
        <span class="stat-pill"><i class="bi bi-x-circle"></i> @ViewBag.RejectedCount Rejected</span>
    </div>
</div>

@* Filter Tabs + Search *@
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
    <div class="filter-tabs mb-0">
        <a href="/Admin/DocumentVerification?filter=all&search=@search" class="filter-tab @(activeFilter == "all" ? "active" : "")">
            All <span class="ms-1 badge @(activeFilter == "all" ? "bg-white text-dark" : "bg-secondary")">@ViewBag.AllCount</span>
        </a>
        <a href="/Admin/DocumentVerification?filter=pending&search=@search" class="filter-tab @(activeFilter == "pending" ? "active" : "")">
            Pending <span class="ms-1 badge @(activeFilter == "pending" ? "bg-white text-dark" : "bg-warning text-dark")">@ViewBag.PendingCount</span>
        </a>
        <a href="/Admin/DocumentVerification?filter=approved&search=@search" class="filter-tab @(activeFilter == "approved" ? "active" : "")">
            Approved <span class="ms-1 badge @(activeFilter == "approved" ? "bg-white text-dark" : "bg-success")">@ViewBag.ApprovedCount</span>
        </a>
        <a href="/Admin/DocumentVerification?filter=rejected&search=@search" class="filter-tab @(activeFilter == "rejected" ? "active" : "")">
            Rejected <span class="ms-1 badge @(activeFilter == "rejected" ? "bg-white text-dark" : "bg-danger")">@ViewBag.RejectedCount</span>
        </a>
    </div>
    <form method="get" action="/Admin/DocumentVerification" class="d-flex gap-2">
        <input type="hidden" name="filter" value="@activeFilter" />
        <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="Search by user name..." style="min-width: 220px;" />
        <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
    </form>
</div>

@if (documents.Any())
{
    <div class="card border-0 shadow-sm" style="border-radius:14px;">
        <div class="card-body p-0">
            <div class="table-responsive doc-table">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">User</th>
                            <th>Role</th>
                            <th>Category</th>
                            <th>Document</th>
                            <th>Status</th>
                            <th>Uploaded</th>
                            <th>Preview</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in documents)
                        {
                            var userName = doc.user_type == "Customer"
                                ? (customerNames.ContainsKey(doc.user_id) ? customerNames[doc.user_id] : "Customer #" + doc.user_id)
                                : (agentNames.ContainsKey(doc.user_id) ? agentNames[doc.user_id] : "Agent #" + doc.user_id);

                            <tr>
                                <td class="ps-4">
                                    <a href="/Admin/UserDocuments?userId=@doc.user_id&userType=@doc.user_type" class="user-link">@userName</a>
                                </td>
                                <td><span class="badge bg-@(doc.user_type == "Customer" ? "info" : "success") bg-opacity-10 text-@(doc.user_type == "Customer" ? "info" : "success")">@doc.user_type</span></td>
                                <td>@doc.category</td>
                                <td>
                                    @doc.document_name
                                    <br /><small class="text-muted">@doc.file_name</small>
                                </td>
                                <td><span class="status-badge status-@doc.status">@doc.status.ToUpper()</span></td>
                                <td><small>@doc.uploaded_at.ToString("dd MMM yyyy HH:mm")</small></td>
                                <td>
                                    <a href="/Document/Preview/@doc.document_id" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
        <h6 class="text-muted">No documents found for this filter.</h6>
        <a href="/Admin/DocumentVerification" class="btn btn-sm btn-outline-secondary mt-2">Clear filters</a>
    </div>
}
