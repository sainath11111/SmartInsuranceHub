@model IEnumerable<SmartInsuranceHub.Models.City>
@{
    ViewData["Title"] = "City Management";
}

<style>
    .city-card-wrap { border-left: 4px solid #2563eb; }
</style>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted small mb-0 text-uppercase fw-bold letter-spacing-1">Admin Panel</p>
        <h3 class="fw-bold mb-0" style="font-family:'Outfit',sans-serif;">City Management</h3>
        <p class="text-muted mb-0 mt-1">Manage the list of service cities used across the platform.</p>
    </div>
    <div class="d-flex gap-2">
        <form method="post" action="/Admin/SeedCities" onsubmit="return confirm('Seed default Indian cities? This will add any missing major cities.')">
            <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-cloud-download me-2"></i>Seed Cities
            </button>
        </form>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#addCityModal">
            <i class="bi bi-plus-circle me-2"></i>Add City
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-x-circle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card-modern p-3 text-center">
            <h4 class="fw-bold text-primary mb-0" style="font-family:'Outfit',sans-serif;">@Model.Count()</h4>
            <small class="text-muted fw-semibold">Total Cities</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card-modern p-3 text-center">
            <h4 class="fw-bold text-success mb-0" style="font-family:'Outfit',sans-serif;">@Model.Count(c => c.is_active)</h4>
            <small class="text-muted fw-semibold">Active Cities</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card-modern p-3 text-center">
            <h4 class="fw-bold text-warning mb-0" style="font-family:'Outfit',sans-serif;">@Model.Count(c => !c.is_active)</h4>
            <small class="text-muted fw-semibold">Inactive</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card-modern p-3 text-center">
            <h4 class="fw-bold text-secondary mb-0" style="font-family:'Outfit',sans-serif;">@Model.Select(c => c.state).Distinct().Count()</h4>
            <small class="text-muted fw-semibold">States Covered</small>
        </div>
    </div>
</div>

<!-- City Table -->
<div class="card-modern">
    <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">All Cities</h5>
        <small class="text-muted">Cities marked inactive won't appear in registration dropdowns</small>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead style="background:#f8fafc;">
                <tr>
                    <th class="ps-4 py-3 text-muted fw-semibold" style="font-size:0.8rem;">CITY NAME</th>
                    <th class="py-3 text-muted fw-semibold" style="font-size:0.8rem;">STATE</th>
                    <th class="py-3 text-muted fw-semibold" style="font-size:0.8rem;">STATUS</th>
                    <th class="py-3 text-muted fw-semibold" style="font-size:0.8rem;">ADDED ON</th>
                    <th class="pe-4 py-3 text-muted fw-semibold text-end" style="font-size:0.8rem;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-geo-alt fs-2 d-block mb-2"></i>
                            No cities found. Add your first city!
                        </td>
                    </tr>
                }
                @foreach (var city in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold" style="width:34px;height:34px;font-size:0.85rem;">
                                    @city.city_name.Substring(0,1)
                                </div>
                                <strong>@city.city_name</strong>
                            </div>
                        </td>
                        <td class="text-muted">@(city.state ?? "—")</td>
                        <td>
                            @if (city.is_active)
                            {
                                <span class="badge rounded-pill" style="background:rgba(16,185,129,0.12); color:#059669; font-size:0.78rem;">
                                    <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Active
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill" style="background:rgba(148,163,184,0.15); color:#64748b; font-size:0.78rem;">
                                    <i class="bi bi-circle me-1" style="font-size:0.5rem;"></i>Inactive
                                </span>
                            }
                        </td>
                        <td class="text-muted" style="font-size:0.875rem;">@city.created_at.ToString("dd MMM yyyy")</td>
                        <td class="pe-4 text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <!-- Edit button -->
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                        data-bs-toggle="modal" data-bs-target="#editCityModal-@city.city_id">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </button>
                                <!-- Toggle status -->
                                <form method="post" action="/Admin/ToggleCity" class="d-inline">
                                    <input type="hidden" name="city_id" value="@city.city_id" />
                                    <button type="submit" class="btn btn-sm @(city.is_active ? "btn-outline-warning" : "btn-outline-success") rounded-pill px-3">
                                        <i class="bi bi-@(city.is_active ? "eye-slash" : "eye") me-1"></i>
                                        @(city.is_active ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                <!-- Delete -->
                                <form method="post" action="/Admin/DeleteCity" class="d-inline" onsubmit="return confirm('Delete @city.city_name permanently?')">
                                    <input type="hidden" name="city_id" value="@city.city_id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    <!-- Edit Modal for each city -->
                    <div class="modal fade" id="editCityModal-@city.city_id" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 rounded-4 shadow-lg">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="modal-title fw-bold">Edit City</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form method="post" action="/Admin/EditCity">
                                    <div class="modal-body pt-3">
                                        <input type="hidden" name="city_id" value="@city.city_id" />
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">City Name</label>
                                            <input type="text" name="city_name" value="@city.city_name" class="form-control rounded-3" required />
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label fw-semibold">State</label>
                                            <input type="text" name="state" value="@city.state" class="form-control rounded-3" placeholder="e.g. Maharashtra" />
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 pt-0">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add City Modal -->
<div class="modal fade" id="addCityModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle text-primary me-2"></i>Add New City</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddCity">
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">City Name <span class="text-danger">*</span></label>
                        <input type="text" name="city_name" class="form-control rounded-3" required placeholder="e.g. Pune" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold">State</label>
                        <input type="text" name="state" class="form-control rounded-3" placeholder="e.g. Maharashtra" />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">
                        <i class="bi bi-check-circle me-1"></i>Add City
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
