@model IEnumerable<SmartInsuranceHub.Models.Query>
@{
    ViewData["Title"] = "Support Queries";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-question-circle text-primary me-2"></i>Support Queries</h2>
        <p class="text-muted mb-0">Manage and reply to customer support tickets.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-2">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-secondary fs-1"></i>
                <h4 class="mt-3">No Queries Yet</h4>
                <p class="text-muted">There are currenty no customer support queries to resolve.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sent Date</th>
                            <th>Customer Info</th>
                            <th>Subject & Message</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var query in Model)
                        {
                            <tr>
                                <td>
                                    <small class="text-muted">@query.send_date.ToString("MMM dd, yyyy")</small><br />
                                    <small class="text-muted">@query.send_date.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    <strong>@query.name</strong><br />
                                    <a class="text-decoration-none small" href="mailto:@query.email">@query.email</a><br />
                                    @if(!string.IsNullOrEmpty(query.phone)){ <small class="text-muted">@query.phone</small> }
                                </td>
                                <td>
                                    <strong>@query.subject</strong>
                                    <p class="small text-muted mb-1" style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@query.message">
                                        @query.message
                                    </p>
                                    @if(query.status == "Resolved")
                                    {
                                        <p class="small text-success mb-0"><strong>Reply:</strong> @query.reply</p>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(query.status == "Resolved" ? "bg-success" : "bg-warning text-dark")">@query.status</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#replyModal-@query.query_id">
                                        @(query.status == "Resolved" ? "View / Edit Reply" : "Reply")
                                    </button>

                                    <!-- Reply Modal -->
                                    <div class="modal fade" id="replyModal-@query.query_id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content border-0 shadow">
                                                <div class="modal-header bg-light border-0">
                                                    <h5 class="modal-title fw-bold">Reply to Ticket #@query.query_id</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form asp-action="ReplyQuery" method="post">
                                                    <div class="modal-body">
                                                        <div class="mb-4 bg-light p-3 rounded">
                                                            <strong class="d-block mb-1 text-dark">Subject: @query.subject</strong>
                                                            <p class="mb-0 text-muted">@query.message</p>
                                                        </div>
                                                        <input type="hidden" name="id" value="@query.query_id" />
                                                        <div class="mb-3">
                                                            <label class="form-label fw-bold">Admin Reply</label>
                                                            <textarea name="reply" class="form-control" rows="4" required>@(query.reply ?? "")</textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer border-0 bg-light">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-primary">Send Reply <i class="bi bi-send ms-1"></i></button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
