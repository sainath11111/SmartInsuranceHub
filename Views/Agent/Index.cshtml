@{
    ViewData["Title"] = "Agent Dashboard";
}

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card dashboard-card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-white-50">Policies Sold</h6>
                        <p class="card-text text-white display-6">@ViewBag.TotalPolicies</p>
                    </div>
                    <div>
                        <i class="bi bi-file-earmark-check fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card dashboard-card bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-white-50">Payments Received</h6>
                        <p class="card-text text-white display-6">₹@ViewBag.TotalPayments</p>
                    </div>
                    <div>
                        <i class="bi bi-cash-coin fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5>Agent Actions</h5>
            </div>
            <div class="card-body p-4">
                <a href="/Agent/Policies" class="btn btn-primary mb-2 w-100"><i class="bi bi-list-check"></i> View Sold Policies</a>
                <p class="text-muted small mt-3">You can view all the policies associated with you and track their status and premium.</p>
            </div>
        </div>
    </div>
</div>
