@model SmartInsuranceHub.Models.Agent
@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col" data-aos="fade-right">
            <h2 class="fw-bold mb-1 text-dark">Agent Profile</h2>
            <p class="text-muted mb-0">Manage your operating boundaries, personal data, and showcase documents.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" data-aos="fade-down">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Profile Form Container -->
        <div class="col-lg-8" data-aos="fade-up">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold text-primary"><i class="bi bi-person-gear me-2"></i> Edit Details</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" asp-controller="Agent" method="post" enctype="multipart/form-data">
                        
                        <div class="row mb-4">
                            <div class="col-12 text-center text-sm-start d-sm-flex align-items-center gap-4">
                                <div class="position-relative d-inline-block shadow-sm rounded-circle p-1 bg-white" style="width: 120px; height: 120px;">
                                    @if (!string.IsNullOrEmpty(Model.profile_photo))
                                    {
                                        <img src="/api/avatar/@Model.profile_photo" alt="Profile" class="rounded-circle w-100 h-100" style="object-fit: cover; border: 3px solid var(--bs-light);">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle w-100 h-100 bg-light text-secondary d-flex justify-content-center align-items-center fw-bold fs-1" style="border: 3px solid #e9ecef;">
                                            @(Model.full_name?.Substring(0, 1)?.ToUpper() ?? "A")
                                        </div>
                                    }
                                </div>
                                <div class="mt-3 mt-sm-0 flex-grow-1">
                                    <h5 class="fw-bold text-dark mb-1">Company Agent</h5>
                                    <p class="text-muted small mb-2">Upload a professional headshot to attract customers.</p>
                                    <input type="file" name="profilePhoto" id="profilePhoto" class="form-control form-control-sm w-auto d-inline-block bg-light" accept="image/*">
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Full Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="full_name" value="@Model.full_name" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control bg-light" name="email" value="@Model.email" readonly>
                                <div class="form-text">Contact admin to change email.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Phone <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="phone" value="@Model.phone" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Date of Birth</label>
                                <input type="date" class="form-control" name="dob" value="@(Model.dob.ToString("yyyy-MM-dd"))">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">PAN Card</label>
                                <input type="text" class="form-control text-uppercase" name="pan" value="@Model.pan" maxlength="10">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Aadhaar Card</label>
                                <input type="text" class="form-control" name="aadhaar" value="@Model.aadhaar" maxlength="12">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-semibold">Experience (Years)</label>
                                <input type="number" class="form-control" name="experience_years" value="@Model.experience_years" min="0" required>
                            </div>

                            <div class="col-12">
                                <label class="form-label text-muted small fw-semibold">Operating Cities <span class="text-danger">*</span></label>
                                <div class="d-flex flex-wrap gap-2 mb-2" id="citiesContainer">
                                    @if(Model.AgentCities != null && Model.AgentCities.Any()) {
                                        foreach(var city in Model.AgentCities) {
                                            <div class="btn-group btn-group-sm mb-1 hide-on-empty">
                                                <input type="hidden" name="cities" value="@city.city_name" />
                                                <button type="button" class="btn btn-primary bg-primary text-white" style="cursor: default;">@city.city_name</button>
                                                <button type="button" class="btn btn-primary btn-remove-city" title="Remove city"><i class="bi bi-x"></i></button>
                                            </div>
                                        }
                                    } else if (!string.IsNullOrEmpty(Model.city)) {
                                        <!-- Legacy fallback -->
                                        <div class="btn-group btn-group-sm mb-1">
                                            <input type="hidden" name="cities" value="@Model.city" />
                                            <button type="button" class="btn btn-primary bg-primary text-white" style="cursor: default;">@Model.city</button>
                                            <button type="button" class="btn btn-primary btn-remove-city"><i class="bi bi-x"></i></button>
                                        </div>
                                    }
                                </div>
                                <div class="input-group input-group-sm">
                                    <input type="text" id="newCityInput" class="form-control" placeholder="Type a city and press Add...">
                                    <button type="button" class="btn btn-outline-primary fw-semibold" id="btnAddCity">Add City</button>
                                </div>
                                <div class="form-text">You can add multiple cities where you operate. Customers in these cities will be able to discover you.</div>
                            </div>
                        </div>

                        <hr class="my-4">
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-semibold shadow-sm">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- System Status & Documents Widget -->
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mb-3">Verification Status</h5>
                    @if(Model.verification_status == "verified") {
                        <div class="display-1 text-success mb-2"><i class="bi bi-check-circle-fill"></i></div>
                        <h4 class="text-success fw-bold">Verified</h4>
                        <p class="text-muted small">You are fully verified and actively receiving customers.</p>
                    } else if (Model.verification_status == "rejected") {
                        <div class="display-1 text-danger mb-2"><i class="bi bi-x-circle-fill"></i></div>
                        <h4 class="text-danger fw-bold">Rejected</h4>
                        <p class="text-muted small">Your profile was rejected. Please review your documents.</p>
                    } else {
                        <div class="display-1 text-warning mb-2"><i class="bi bi-exclamation-circle-fill"></i></div>
                        <h4 class="text-warning fw-bold">Pending</h4>
                        <p class="text-muted small">Your profile is currently under review by the company.</p>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-folder-check me-2 text-primary"></i> Uploaded Documents</h6>
                    <a href="/Document/Profile" class="btn btn-sm btn-outline-secondary rounded-pill" style="font-size: 0.75rem;">Manage</a>
                </div>
                <div class="card-body p-3">
                    @{
                        var docs = ViewBag.Documents as IEnumerable<SmartInsuranceHub.Models.UserDocument>;
                        if (docs != null && docs.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var doc in docs)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2 border-bottom-0">
                                        <div class="d-flex align-items-center overflow-hidden">
                                            <i class="bi bi-file-earmark-text text-muted fs-4 me-3"></i>
                                            <div class="text-truncate">
                                                <h6 class="mb-0 fw-semibold text-truncate fs-6" style="max-width: 150px;">@doc.document_name</h6>
                                                <small class="text-muted text-uppercase" style="font-size: 0.65rem;">@doc.category</small>
                                            </div>
                                        </div>
                                        @if(doc.status == "approved") { <span class="badge bg-success rounded-pill"><i class="bi bi-check me-1"></i></span> }
                                        else if (doc.status == "rejected") { <span class="badge bg-danger rounded-pill"><i class="bi bi-x me-1"></i></span> }
                                        else { <span class="badge bg-warning text-dark rounded-pill"><i class="bi bi-clock me-1"></i></span> }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-1 mb-2"></i>
                                <p class="small mb-0">No documents found.<br><a href="/Document/Profile">Upload mandatory documents</a></p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btnAddCity = document.getElementById('btnAddCity');
            const newCityInput = document.getElementById('newCityInput');
            const citiesContainer = document.getElementById('citiesContainer');

            function attachRemoveEvent(btn) {
                btn.addEventListener('click', function(e) {
                    e.target.closest('.btn-group').remove();
                });
            }

            // Attach to existing
            document.querySelectorAll('.btn-remove-city').forEach(btn => attachRemoveEvent(btn));

            function addCity() {
                const val = newCityInput.value.trim();
                if (!val) return;
                
                // Check duplicate
                let exists = false;
                document.querySelectorAll('input[name="cities"]').forEach(inp => {
                    if (inp.value.toLowerCase() === val.toLowerCase()) exists = true;
                });
                
                if (exists) {
                    newCityInput.value = '';
                    return;
                }

                // Append
                const group = document.createElement('div');
                group.className = 'btn-group btn-group-sm mb-1';
                group.innerHTML = `
                    <input type="hidden" name="cities" value="${val}" />
                    <button type="button" class="btn btn-primary bg-primary text-white" style="cursor: default;">${val}</button>
                    <button type="button" class="btn btn-primary btn-remove-city"><i class="bi bi-x"></i></button>
                `;
                citiesContainer.appendChild(group);
                attachRemoveEvent(group.querySelector('.btn-remove-city'));
                newCityInput.value = '';
            }

            btnAddCity.addEventListener('click', addCity);
            newCityInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addCity();
                }
            });
        });
    </script>
}
