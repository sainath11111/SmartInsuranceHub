@model IEnumerable<SmartInsuranceHub.Models.PolicyRequest>
@{
    ViewData["Title"] = "My Policy Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h2 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif;">
        <i class="bi bi-journal-text text-primary me-2"></i>My Policy Requests
    </h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5" data-aos="fade-up">
        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
            <i class="bi bi-folder2-open text-muted fs-1"></i>
        </div>
        <h5 class="fw-bold text-dark">No Requests Found</h5>
        <p class="text-muted">You haven't requested any policies yet.</p>
        <a href="/Customer/BrowsePlans" class="btn btn-primary rounded-pill px-4">Browse Plans</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4" data-aos="fade-up">
                <div class="card-modern p-4 h-100 position-relative border-0 shadow-sm">
                    @if (item.status == "pending")
                    {
                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i> Pending Review</span>
                    }
                    else if (item.status == "approved")
                    {
                        <span class="badge bg-success position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> Approved</span>
                    }
                    else
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> Rejected</span>
                    }

                    <div class="text-muted small mb-2"><i class="bi bi-calendar-event me-1"></i> @item.created_at.ToString("dd MMM yyyy")</div>
                    <h5 class="fw-bold mb-3 text-dark pe-5 mt-1" style="min-height: 48px;">@item.InsurancePlan?.plan_name</h5>

                    <div class="bg-light rounded p-3 mb-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-person-badge text-primary fs-5"></i>
                            <div>
                                <p class="mb-0 fw-semibold text-dark lh-sm">@item.Agent?.full_name</p>
                                <p class="mb-0 text-muted small lh-sm">Agent &bull; @item.Agent?.Company?.company_name</p>
                            </div>
                        </div>
                    </div>

                    @if (item.status == "rejected")
                    {
                        <div class="alert alert-danger py-2 px-3 small border-danger">
                            <strong>Reason:</strong> @(item.rejection_reason ?? "No reason provided by agent.")
                        </div>
                    }
                    else if (item.status == "approved")
                    {
                        <div class="alert alert-success py-2 px-3 small border-success">
                            Approved on @item.reviewed_at?.ToString("dd MMM yyyy"). An active policy has been generated for you. <a href="/Customer/MyPolicies" class="alert-link">View Policies</a>
                        </div>
                    }

                </div>
            </div>
        }
    </div>
}
