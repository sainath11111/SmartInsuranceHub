@model SmartInsuranceHub.Models.Query
@{
    ViewData["Title"] = "Contact & Support";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card dashboard-card">
            <div class="card-header bg-white pt-4 pb-2 px-4 border-0">
                <h4 class="mb-0">Submit a Query</h4>
            </div>
            <div class="card-body p-4">
                @if(ViewBag.Message != null)
                {
                    <div class="alert alert-success">@ViewBag.Message</div>
                }
                
                <form method="post" action="/Customer/SubmitQuery">
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input type="text" asp-for="subject" class="form-control" placeholder="What do you need help with?" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Message</label>
                        <textarea asp-for="message" class="form-control" rows="5" placeholder="Describe your issue or query..." required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-2">Submit Query <i class="bi bi-send ms-2"></i></button>
                </form>
            </div>
        </div>
        
        <!-- My Previous Queries Section -->
        @if (ViewBag.Queries != null && ((IEnumerable<SmartInsuranceHub.Models.Query>)ViewBag.Queries).Any())
        {
            <div class="mt-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-clock-history text-secondary me-2"></i>My Support Tickets</h5>
                <div class="accordion shadow-sm" id="queriesAccordion">
                    @{
                        int index = 0;
                        foreach (var q in (IEnumerable<SmartInsuranceHub.Models.Query>)ViewBag.Queries!)
                        {
                            var headerId = "heading" + index;
                            var collapseId = "collapse" + index;
                            <div class="accordion-item border-0 mb-3 rounded overflow-hidden">
                                <h2 class="accordion-header" id="@headerId">
                                    <button class="accordion-button collapsed fw-semibold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                        <div class="d-flex w-100 justify-content-between align-items-center me-3">
                                            <span>@q.subject</span>
                                            <span class="badge @(q.status == "Resolved" ? "bg-success" : "bg-warning text-dark")">@q.status</span>
                                        </div>
                                    </button>
                                </h2>
                                <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headerId" data-bs-parent="#queriesAccordion">
                                    <div class="accordion-body bg-light position-relative">
                                        <div class="text-muted small mb-2"><i class="bi bi-calendar3 me-1"></i>@q.send_date.ToString("MMM dd, yyyy HH:mm")</div>
                                        <div class="p-3 bg-white rounded border-start border-4 border-primary mb-3">
                                            <strong>You asked:</strong>
                                            <p class="mb-0 mt-1 text-secondary">@q.message</p>
                                        </div>
                                        
                                        @if (!string.IsNullOrEmpty(q.reply))
                                        {
                                            <div class="p-3 bg-white rounded border-start border-4 border-success mt-2">
                                                <strong><i class="bi bi-headset text-success me-1"></i>Admin Reply:</strong>
                                                <p class="mb-0 mt-1 text-secondary">@q.reply</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted fst-italic mt-2"><i class="bi bi-info-circle me-1"></i>We have received your query and an admin will reply soon.</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            index++;
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>
