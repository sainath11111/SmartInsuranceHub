@model SmartInsuranceHub.Models.Agent
@{
    ViewData["Title"] = "Agent Profile - " + Model.full_name;
    var plans = ViewBag.Plans as List<SmartInsuranceHub.Models.InsurancePlan>;
}

<div class="container py-4">
    <div class="row mb-5" data-aos="fade-down">
        <div class="col-md-4 text-center">
            <div class="rounded-circle bg-primary bg-opacity-10 text-primary mx-auto d-flex align-items-center justify-content-center mb-3 fw-bold" style="width: 150px; height: 150px; font-size: 4rem;">
                @Model.full_name.Substring(0, 1).ToUpper()
            </div>
        </div>
        <div class="col-md-8">
            <div class="d-flex align-items-center gap-3 mb-2">
                <h2 class="fw-bold mb-0">@Model.full_name</h2>
                <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1"><i class="bi bi-patch-check-fill me-1"></i>Verified Agent</span>
            </div>
            <h5 class="text-primary mb-4">@Model.Company?.company_name</h5>
            
            <div class="row g-3">
                <div class="col-sm-6">
                    <p class="text-muted small mb-1">Location</p>
                    <p class="fw-semibold"><i class="bi bi-geo-alt me-2 text-primary"></i>@Model.city, @Model.pincode</p>
                </div>
                <div class="col-sm-6">
                    <p class="text-muted small mb-1">Experience</p>
                    <p class="fw-semibold"><i class="bi bi-briefcase me-2 text-primary"></i>@Model.experience_years years</p>
                </div>
                <div class="col-sm-6">
                    <p class="text-muted small mb-1">Contact Details</p>
                    <p class="fw-semibold"><i class="bi bi-info-circle me-2 text-primary"></i>Email & Phone shared post-approval</p>
                </div>
            </div>
        </div>
    </div>

    <hr class="mb-5 text-muted opacity-25" />

    <h4 class="fw-bold mb-4" data-aos="fade-up"><i class="bi bi-shield-check text-primary me-2"></i>Policies Handled by @Model.full_name</h4>
    
    @if (plans != null && plans.Any())
    {
        <div class="row g-4">
            @foreach (var plan in plans)
            {
                <div class="col-md-6 col-lg-4" data-aos="fade-up">
                    <div class="card-modern p-4 h-100">
                        <h6 class="fw-bold mb-2 text-dark">@plan.plan_name</h6>
                        <p class="text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@plan.description</p>
                        
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="fw-bold text-primary">₹@plan.premium_amount.ToString("N0") <small class="text-muted">/yr</small></span>
                            <span class="text-muted small">Cov: ₹@plan.coverage_amount.ToString("N0")</span>
                        </div>

                        <form method="post" action="/Customer/RequestPolicy">
                            <input type="hidden" name="planId" value="@plan.plan_id" />
                            <input type="hidden" name="companyId" value="@plan.company_id" />
                            <input type="hidden" name="agentId" value="@Model.agent_id" />
                            <button type="submit" class="btn btn-outline-primary w-100 rounded-pill btn-sm fw-bold">
                                Request this Policy
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No active policies available from this company right now.</p>
    }
</div>
