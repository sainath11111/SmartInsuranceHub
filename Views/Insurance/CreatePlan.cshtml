@model SmartInsuranceHub.Models.InsurancePlan
@{
    ViewData["Title"] = "Create Insurance Plan";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card dashboard-card">
            <div class="card-body p-4">
                <form method="post" action="/Insurance/CreatePlan">
                    <div class="mb-3">
                        <label class="form-label">Plan Name</label>
                        <input type="text" asp-for="plan_name" class="form-control" required />
                    </div>
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Select Category</label>
                            <select asp-for="type_id" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                @foreach(var t in ViewBag.Types)
                                {
                                    <option value="@t.type_id">@t.type_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Premium Amount (₹)</label>
                            <input type="number" asp-for="premium_amount" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Coverage Amount (₹)</label>
                            <input type="number" asp-for="coverage_amount" class="form-control" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Duration (Months)</label>
                            <input type="number" asp-for="duration_months" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Plan Description</label>
                        <textarea asp-for="description" class="form-control" rows="3" required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-success py-2 w-100 fw-semibold">Launch Plan</button>
                    <a href="/Insurance/Index" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
