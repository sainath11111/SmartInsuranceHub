<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- Authenticated Navbar -->
    <nav class="navbar navbar-expand-lg navbar-main sticky-top shadow-sm px-lg-4">
        <div class="container-fluid align-items-center">
            <a class="navbar-brand d-flex align-items-center" href="javascript:void(0)" style="cursor: default; text-decoration: none;">
                <img src="~/images/logo.png" alt="SmartInsurance" height="32" class="me-2" style="border-radius: 6px;">
                <span class="text-secondary fs-5">Smart<span class="text-primary">Insurance</span></span>
            </a>
            
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 ms-lg-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" href="/Admin/Index"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Companies" ? "active" : "")" href="/Admin/Companies"><i class="bi bi-buildings me-1"></i> Companies</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Agents" ? "active" : "")" href="/Admin/Agents"><i class="bi bi-person-badge me-1"></i> Agents</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Customers" ? "active" : "")" href="/Admin/Customers"><i class="bi bi-people me-1"></i> Customers</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "InsuranceTypes" ? "active" : "")" href="/Admin/InsuranceTypes"><i class="bi bi-tags me-1"></i> Categories</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && (ViewContext.RouteData.Values["Action"]?.ToString() == "DocumentVerification" || ViewContext.RouteData.Values["Action"]?.ToString() == "UserDocuments") ? "active" : "")" href="/Admin/DocumentVerification"><i class="bi bi-shield-check me-1"></i> Doc Verify</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "ManageAds" ? "active" : "")" href="/Admin/ManageAds"><i class="bi bi-megaphone me-1"></i> Ads</a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Query" ? "active" : "")" href="/Query/Index"><i class="bi bi-chat-left-text me-1"></i> Queries</a></li>
                        }
                        else if (User.IsInRole("Company"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Company/Index"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Company/Analytics"><i class="bi bi-graph-up me-1"></i> Analytics</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Insurance/Index"><i class="bi bi-shield-check me-1"></i> Our Plans</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Advertisement/MyAds"><i class="bi bi-megaphone me-1"></i> Advertisements</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Company/Agents"><i class="bi bi-person-badge me-1"></i> My Agents</a></li>
                        }
                        else if (User.IsInRole("Agent"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Agent/Index"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Agent/Policies"><i class="bi bi-file-earmark-text me-1"></i> Policies Sold</a></li>
                            <li class="nav-item">
                                <button class="nav-link btn btn-link text-decoration-none" onclick="openAgentChat()"><i class="bi bi-chat-dots me-1"></i> Company Chat</button>
                            </li>
                            <li class="nav-item"><a class="nav-link" href="/CustomerAgentChat"><i class="bi bi-chat-text me-1"></i> Customer Chat</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Agent/Profile"><i class="bi bi-person-gear me-1"></i> Edit Profile</a></li>
                        }
                        else if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Customer/Index"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/BrowsePlans"><i class="bi bi-search me-1"></i> Browse Plans</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/MyPolicies"><i class="bi bi-shield-check me-1"></i> My Policies</a></li>
                            <li class="nav-item"><a class="nav-link" href="/CustomerAgentChat"><i class="bi bi-person-lines-fill me-1"></i> Nearest Agents</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/SubmitQuery"><i class="bi bi-question-circle me-1"></i> Support</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Document/Profile"><i class="bi bi-person-lines-fill me-1"></i> Profile & Docs</a></li>
                        }
                    }
                </ul>
                
                <div class="d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var profilePhotoClaim = User.Claims.FirstOrDefault(c => c.Type == "ProfilePhoto")?.Value;
                        <div class="dropdown">
                            <a class="nav-user dropdown-toggle text-decoration-none d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(profilePhotoClaim))
                                {
                                    <img src="/api/avatar/@profilePhotoClaim" alt="Profile" class="rounded-circle shadow-sm me-2" style="width: 28px; height: 28px; object-fit: cover; border: 1px solid var(--bs-border-color);" onerror="this.src='https://ui-avatars.com/api/?name=' + encodeURIComponent('@User.Identity?.Name') + '&background=random'" />
                                }
                                else
                                {
                                    <span class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                        @(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")
                                    </span>
                                }
                                <span>@User.Identity?.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3">
                                <li>
                                    <div class="px-3 py-2 text-muted small border-bottom mb-1">
                                        Signed in as <br/>
                                        <strong class="text-dark">@User.Identity?.Name</strong>
                                    </div>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item py-2" href="/Admin/Index"><i class="bi bi-person me-2 text-primary"></i> My Profile</a></li>
                                }
                                else if (User.IsInRole("Company"))
                                {
                                    <li><a class="dropdown-item py-2" href="/Company/Index"><i class="bi bi-person me-2 text-primary"></i> My Profile</a></li>
                                }
                                else if (User.IsInRole("Agent"))
                                {
                                    <li><a class="dropdown-item py-2" href="/Agent/Profile"><i class="bi bi-person me-2 text-primary"></i> My Profile</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item py-2" href="/Document/Profile"><i class="bi bi-person me-2 text-primary"></i> My Profile</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-outline-smart me-2">Log In</a>
                        <a href="/Auth/RegisterCustomer" class="btn btn-brand">Sign Up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Content Area -->
    <div class="container-fluid px-lg-4 content-area mt-4 mb-5 flex-grow-1" style="position: relative;">
        <div class="mb-3 d-flex justify-content-start">
            <button type="button" class="btn btn-outline-secondary bg-white btn-sm shadow-sm rounded-pill fw-medium px-3" onclick="window.history.back();" style="transition: all 0.2s ease;">
                <i class="bi bi-arrow-left me-1"></i> Back
            </button>
        </div>
        @RenderBody()
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    @if (User.IsInRole("Agent"))
    {
        <!-- Agent Chat Offcanvas -->
        <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="agentChatOffcanvas" aria-labelledby="agentChatLabel" style="width: 400px; border-left: none;">
          <div class="offcanvas-header bg-primary text-white">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-chat-quote-fill fs-5"></i>
                <h5 class="offcanvas-title fw-bold" id="agentChatLabel">Company Support</h5>
            </div>
            <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body d-flex flex-column p-0 bg-light">
            <div id="agentChatMessages" class="flex-grow-1 overflow-auto p-3" style="max-height: calc(100vh - 140px);">
                <!-- Messages will be injected here -->
            </div>
            <div class="p-3 bg-white border-top">
                <form id="agentChatForm">
                  <div class="input-group">
                    <input type="text" id="agentChatInput" class="form-control rounded-pill rounded-end-0 bg-light border-end-0 px-3" placeholder="Type your message..." required autocomplete="off" />
                    <button class="btn btn-primary rounded-pill rounded-start-0 px-3" type="submit"><i class="bi bi-send-fill"></i></button>
                  </div>
                </form>
            </div>
          </div>
        </div>
        <script>
            let agentChatPollInterval = null;
            let agentIdForChat = null;

            async function openAgentChat() {
                const res = await fetch('/api/chat/myid');
                if (res.ok) {
                    const data = await res.json();
                    agentIdForChat = data.agentId;
                }
                var myOffcanvas = new bootstrap.Offcanvas(document.getElementById('agentChatOffcanvas'));
                myOffcanvas.show();
                fetchAgentMessages();
                if (agentChatPollInterval) clearInterval(agentChatPollInterval);
                agentChatPollInterval = setInterval(fetchAgentMessages, 3000);
            }

            document.getElementById('agentChatOffcanvas').addEventListener('hidden.bs.offcanvas', function () {
                if (agentChatPollInterval) clearInterval(agentChatPollInterval);
            });

            async function fetchAgentMessages() {
                if (!agentIdForChat) return;
                try {
                    const res = await fetch(`/api/chat/${agentIdForChat}`);
                    if (res.ok) {
                        const messages = await res.json();
                        renderAgentMessages(messages);
                    }
                } catch (err) { console.error('Error fetching agent messages', err); }
            }

            function renderAgentMessages(messages) {
                const container = document.getElementById('agentChatMessages');
                container.innerHTML = '';
                messages.forEach(m => {
                    const isMine = m.sender_type === 'Agent';
                    const msgDiv = document.createElement('div');
                    msgDiv.className = `d-flex mb-3 ${isMine ? 'justify-content-end' : 'justify-content-start'}`;
                    const bubble = document.createElement('div');
                    bubble.className = `px-3 py-2 rounded-4 shadow-sm ${isMine ? 'bg-primary text-white rounded-bottom-end-0' : 'bg-white text-dark border border-light rounded-bottom-start-0'}`;
                    bubble.style.maxWidth = '85%';
                    bubble.style.fontSize = '0.95rem';
                    const txt = document.createElement('span');
                    txt.innerText = m.message_text;
                    bubble.appendChild(txt);
                    const time = document.createElement('div');
                    time.className = `mt-1 text-end ${isMine ? 'text-white-50' : 'text-muted'}`;
                    time.style.fontSize = '0.7rem';
                    time.innerText = new Date(m.sent_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    bubble.appendChild(time);
                    msgDiv.appendChild(bubble);
                    container.appendChild(msgDiv);
                });
                container.scrollTop = container.scrollHeight;
            }

            document.getElementById('agentChatForm').addEventListener('submit', async function (e) {
                e.preventDefault();
                const input = document.getElementById('agentChatInput');
                const text = input.value.trim();
                if (!text || !agentIdForChat) return;
                try {
                    const res = await fetch(`/api/chat/${agentIdForChat}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ messageText: text })
                    });
                    if (res.ok) {
                        input.value = '';
                        fetchAgentMessages();
                    }
                } catch (err) { console.error('Send error', err); }
            });
        </script>
        
        <style>
            .hover-primary { transition: color 0.2s; }
            .hover-primary:hover { color: var(--primary) !important; }
            .rounded-bottom-end-0 { border-bottom-right-radius: 0 !important; }
            .rounded-bottom-start-0 { border-bottom-left-radius: 0 !important; }
        </style>
    }
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>AOS.init({ duration: 600, easing: 'ease-out-cubic', once: true, offset: 40 });</script>
</body>
</html>
