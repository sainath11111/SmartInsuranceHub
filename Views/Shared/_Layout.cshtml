<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-main">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="~/images/logo.png" alt="SmartInsurance" class="navbar-logo">
                <span>SmartInsurance</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Admin/Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Admin/Companies">Companies</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Admin/Agents">Agents</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Admin/Customers">Customers</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Admin/InsuranceTypes">Categories</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Query/Index">Queries</a></li>
                        }
                        else if (User.IsInRole("Company"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Company/Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Insurance/Index">Our Plans</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Company/Agents">My Agents</a></li>
                        }
                        else if (User.IsInRole("Agent"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Agent/Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Agent/Policies">Policies Sold</a></li>
                            <li class="nav-item">
                                <button class="nav-link btn btn-link" onclick="openAgentChat()">Company Chat</button>
                            </li>
                            <li class="nav-item"><a class="nav-link" href="/Document/Profile">Profile & Documents</a></li>
                        }
                        else if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Customer/Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/BrowsePlans">Browse Plans</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/MyPolicies">My Policies</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Customer/SubmitQuery">Help & Support</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Document/Profile">Profile & Documents</a></li>
                        }
                    }
                </ul>
                <div class="d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a class="nav-user dropdown-toggle text-decoration-none" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span>@User.Identity?.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i> Logout</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-primary-smart">Login</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div class="container content-area">
        @RenderBody()
    </div>

    <footer class="footer-main">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <div class="navbar-brand mb-3">
                        <img src="~/images/logo.png" alt="SmartInsurance" class="navbar-logo">
                        <span>SmartInsurance</span>
                    </div>
                    <p class="text-muted small">Your trusted partner for all insurance needs. We provide secure, transparent, and efficient insurance solutions for everyone.</p>
                </div>
                <div class="col-md-2 offset-md-1 mb-4 mb-md-0">
                    <h5 class="footer-heading">Quick Links</h5>
                    <a href="/" class="footer-link">Home</a>
                    <a href="/Customer/BrowsePlans" class="footer-link">Policies</a>
                    <a href="/Query/Index" class="footer-link">Claims</a>
                    <a href="/Customer/SubmitQuery" class="footer-link">Contact</a>
                </div>
                <div class="col-md-2 mb-4 mb-md-0">
                    <h5 class="footer-heading">Company</h5>
                    <a href="#" class="footer-link">About Us</a>
                    <a href="#" class="footer-link">Privacy Policy</a>
                    <a href="#" class="footer-link">Terms of Service</a>
                </div>
                <div class="col-md-3">
                    <h5 class="footer-heading">Contact Us</h5>
                    <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-2 text-primary"></i> 123 Insurance Way, Tech City</p>
                    <p class="text-muted small mb-2"><i class="bi bi-envelope me-2 text-primary"></i> support@smartinsurance.com</p>
                    <p class="text-muted small"><i class="bi bi-telephone me-2 text-primary"></i> +1 (555) 123-4567</p>
                </div>
            </div>
            <div class="footer-bottom text-center">
                <p class="mb-0">&copy; @DateTime.Now.Year SmartInsurance Hub. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    @if (User.IsInRole("Agent"))
    {
        <div class="offcanvas offcanvas-end" tabindex="-1" id="agentChatOffcanvas" aria-labelledby="agentChatLabel">
          <div class="offcanvas-header bg-success text-white">
            <h5 class="offcanvas-title" id="agentChatLabel"><i class="bi bi-chat-dots"></i> Chat with Company</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body d-flex flex-column" style="background-color:#f8f9fa;">
            <div id="agentChatMessages" class="flex-grow-1 overflow-auto mb-3 p-2 rounded bg-white shadow-sm border" style="max-height: calc(100vh - 180px);">
            </div>
            <form id="agentChatForm">
              <div class="input-group">
                <input type="text" id="agentChatInput" class="form-control" placeholder="Type a message..." required autocomplete="off" />
                <button class="btn btn-success" type="submit"><i class="bi bi-send"></i></button>
              </div>
            </form>
          </div>
        </div>
        <script>
            let agentChatPollInterval = null;
            let agentIdForChat = null;

            async function openAgentChat() {
                const res = await fetch('/api/chat/myid');
                if (res.ok) {
                    const data = await res.json();
                    agentIdForChat = data.agentId;
                }
                var myOffcanvas = new bootstrap.Offcanvas(document.getElementById('agentChatOffcanvas'));
                myOffcanvas.show();
                fetchAgentMessages();
                if (agentChatPollInterval) clearInterval(agentChatPollInterval);
                agentChatPollInterval = setInterval(fetchAgentMessages, 3000);
            }

            document.getElementById('agentChatOffcanvas').addEventListener('hidden.bs.offcanvas', function () {
                if (agentChatPollInterval) clearInterval(agentChatPollInterval);
            });

            async function fetchAgentMessages() {
                if (!agentIdForChat) return;
                try {
                    const res = await fetch(`/api/chat/${agentIdForChat}`);
                    if (res.ok) {
                        const messages = await res.json();
                        renderAgentMessages(messages);
                    }
                } catch (err) { console.error('Error fetching agent messages', err); }
            }

            function renderAgentMessages(messages) {
                const container = document.getElementById('agentChatMessages');
                container.innerHTML = '';
                messages.forEach(m => {
                    const isMine = m.sender_type === 'Agent';
                    const msgDiv = document.createElement('div');
                    msgDiv.className = `d-flex mb-2 ${isMine ? 'justify-content-end' : 'justify-content-start'}`;
                    const bubble = document.createElement('div');
                    bubble.className = `p-2 rounded ${isMine ? 'bg-success text-white' : 'bg-light border'}`;
                    bubble.style.maxWidth = '80%';
                    const txt = document.createElement('span');
                    txt.innerText = m.message_text;
                    bubble.appendChild(txt);
                    const time = document.createElement('small');
                    time.className = `d-block mt-1 ${isMine ? 'text-white-50' : 'text-muted'}`;
                    time.style.fontSize = '0.7rem';
                    time.innerText = new Date(m.sent_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    bubble.appendChild(time);
                    msgDiv.appendChild(bubble);
                    container.appendChild(msgDiv);
                });
                container.scrollTop = container.scrollHeight;
            }

            document.getElementById('agentChatForm').addEventListener('submit', async function (e) {
                e.preventDefault();
                const input = document.getElementById('agentChatInput');
                const text = input.value.trim();
                if (!text || !agentIdForChat) return;
                try {
                    const res = await fetch(`/api/chat/${agentIdForChat}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ messageText: text })
                    });
                    if (res.ok) {
                        input.value = '';
                        fetchAgentMessages();
                    }
                } catch (err) { console.error('Send error', err); }
            });
        </script>
    }
</body>
</html>
