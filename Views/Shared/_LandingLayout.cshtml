<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
            overflow-x: hidden;
        }
        
        /* Modern Navbar */
        .landing-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }
        .nav-link {
            font-weight: 500;
            color: #475569;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s;
        }
        .nav-link:hover, .nav-link.active {
            color: #0d6efd;
        }
        .btn-brand {
            background-color: #0d6efd;
            color: white;
            font-weight: 500;
            border-radius: 8px;
            padding: 0.5rem 1.5rem;
            transition: all 0.2s;
        }
        .btn-brand:hover {
            background-color: #0b5ed7;
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }
        .contact-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .contact-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #eff6ff;
            color: #0d6efd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }
        
        /* Footer */
        .landing-footer {
            background-color: #0f172a;
            color: #94a3b8;
            padding: 4rem 0 2rem;
        }
        .landing-footer h5 {
            color: #f8fafc;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }
        .landing-footer a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.2s;
        }
        .landing-footer a:hover {
            color: #f8fafc;
        }
    </style>
</head>
<body>
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg landing-navbar sticky-top py-3">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center fw-bold text-dark fs-4" href="/">
                <img src="~/images/logo.png" alt="SmartInsurance" height="30" class="me-2" style="border-radius: 4px;">
                Smart<span class="text-primary">Insurance</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/insurance">Insurance</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/companies">Companies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/News/Index">News</a>
                    </li>
                </ul>
                
                <!-- Right Actions -->
                <div class="d-flex align-items-center gap-4">
                    <a href="#" class="text-dark"><i class="bi bi-search"></i></a>
                    
                    <a href="/Auth/Login" class="btn btn-brand">Login</a>
                    
                    <div class="contact-box d-none d-xl-flex border-start ps-4 ms-2">
                        <div class="contact-icon">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-dark">+92 (003) 68-090</div>
                            <div class="small text-muted" style="font-size: 0.8rem;">Call to Our Experts</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Simple Footer -->
    <footer class="landing-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="d-flex align-items-center fw-bold fs-4 text-white mb-3">
                        <img src="~/images/logo.png" alt="SmartInsurance" height="30" class="me-2 rounded">
                        Smart<span class="text-primary">Insurance</span>
                    </div>
                    <p class="mb-4 text-muted pe-md-5">We provide the best insurance policies to protect what matters most—your family, health, and future.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/">Home</a></li>
                        <li class="mb-2"><a href="/about">About Us</a></li>
                        <li class="mb-2"><a href="/insurance">Insurance</a></li>
                        <li class="mb-2"><a href="/Auth/Login">Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5>Contact Info</h5>
                    <ul class="list-unstyled text-muted">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-primary"></i> 123 Insurance Ave, NY 10001</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2 text-primary"></i> contact@insur.com</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2 text-primary"></i> +92 (003) 68-090</li>
                    </ul>
                </div>
            </div>
            <div class="border-top border-secondary pt-4 mt-4 text-center">
                <p class="mb-0 text-muted small">&copy; @DateTime.Now.Year Smart Insurance Hub. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
