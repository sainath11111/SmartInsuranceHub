<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Insurance Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg landing-navbar">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center" href="javascript:void(0)" style="cursor: default; text-decoration: none;">
                <img src="~/images/logo.png" alt="SmartInsurance" height="36" class="me-2" style="border-radius: 8px;">
                <span class="text-secondary">Smart</span><span class="text-primary">Insurance</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-2">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")" href="/about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Insurance" ? "active" : "")" href="/insurance">Insurance</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Companies" ? "active" : "")" href="/companies">Companies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "News" ? "active" : "")" href="/News/Index">News</a>
                    </li>
                </ul>
                
                <!-- Right Actions -->
                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/" class="btn btn-outline-smart">
                            <i class="bi bi-speedometer2 me-1"></i> Dashboard
                        </a>
                        <a href="/Auth/Logout" class="btn btn-brand">Log Out</a>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-outline-smart">Login</a>
                        <a href="/Auth/RegisterCustomer" class="btn btn-brand">Sign Up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Modern Footer -->
    <footer class="landing-footer">
        <div class="container">
            <div class="row border-bottom border-secondary pb-5 mb-4">
                <div class="col-lg-5 col-md-12 mb-4 mb-lg-0">
                    <div class="d-flex align-items-center fw-bold fs-3 text-white mb-3">
                        <img src="~/images/logo.png" alt="SmartInsurance" height="36" class="me-2 rounded bg-white p-1">
                        <span>Smart<span style="color: var(--primary-light);">Insurance</span></span>
                    </div>
                    <p class="text-muted pe-lg-5 mb-4 line-height-lg" style="font-size: 1.05rem;">
                        Empowering you with comprehensive, transparent, and seamlessly integrated insurance solutions. Discover unparalleled protection for your family, health, and future.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="#" class="btn btn-sm btn-outline-secondary text-muted rounded-circle" style="width:40px;height:40px;display:inline-flex;align-items:center;justify-content:center;"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-secondary text-muted rounded-circle" style="width:40px;height:40px;display:inline-flex;align-items:center;justify-content:center;"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-secondary text-muted rounded-circle" style="width:40px;height:40px;display:inline-flex;align-items:center;justify-content:center;"><i class="bi bi-facebook"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0 offset-lg-1">
                    <h5 class="mb-4">Company</h5>
                    <ul class="list-unstyled">
                        <li><a href="/about" class="footer-link">About Us</a></li>
                        <li><a href="/News/Index" class="footer-link">Latest News</a></li>
                        <li><a href="#" class="footer-link">Careers</a></li>
                        <li><a href="#" class="footer-link">Contact</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                    <h5 class="mb-4">Services</h5>
                    <ul class="list-unstyled">
                        <li><a href="/insurance" class="footer-link">Find Policies</a></li>
                        <li><a href="/companies" class="footer-link">Our Partners</a></li>
                        <li><a href="/Auth/RegisterAgent" class="footer-link">Become an Agent</a></li>
                        <li><a href="#" class="footer-link">File a Claim</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-2 col-md-4">
                    <h5 class="mb-4">Legal</h5>
                    <ul class="list-unstyled">
                        <li><a href="/Home/Privacy" class="footer-link">Privacy Policy</a></li>
                        <li><a href="/Home/Terms" class="footer-link">Terms of Service</a></li>
                        <li><a href="#" class="footer-link">Cookie Policy</a></li>
                        <li><a href="#" class="footer-link">Compliance</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom pb-4">
                <span class="text-muted">&copy; @DateTime.Now.Year Smart Insurance Hub. All rights reserved.</span>
                <span class="text-muted d-flex align-items-center"><i class="bi bi-globe me-2"></i> English (US)</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
