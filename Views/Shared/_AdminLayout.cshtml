<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --admin-sidebar-width: 260px;
            --admin-bg: #f8fafc;
        }

        body {
            background-color: var(--admin-bg);
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3, h4, h5, h6, .brand-text {
            font-family: 'Outfit', sans-serif;
        }

        /* Sidebar Styles */
        .admin-sidebar {
            width: var(--admin-sidebar-width);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
        }

        .sidebar-header {
            height: 70px;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .sidebar-nav {
            padding: 1.5rem 1rem;
            flex-grow: 1;
            overflow-y: auto;
        }

        .nav-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            font-weight: 700;
            margin: 1.5rem 0 0.75rem 0.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 0.65rem 1rem;
            color: #475569;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 0.25rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .sidebar-link:hover {
            color: var(--primary);
            background: #f1f5f9;
        }

        .sidebar-link.active {
            color: var(--primary);
            background: #eff6ff;
            font-weight: 600;
        }

        .sidebar-link i {
            font-size: 1.1rem;
            margin-right: 0.75rem;
            opacity: 0.7;
        }
        
        .sidebar-link.active i {
            opacity: 1;
        }

        /* Main Content Styles */
        .admin-wrapper {
            margin-left: var(--admin-sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.3s ease;
        }

        .admin-header {
            height: 70px;
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .admin-content {
            padding: 2rem;
            flex-grow: 1;
        }

        /* Responsive Mobile */
        @@media (max-width: 991.98px) {
            .admin-sidebar {
                transform: translateX(-100%);
            }
            .admin-sidebar.show {
                transform: translateX(0);
                box-shadow: 4px 0 24px rgba(0,0,0,0.1);
            }
            .admin-wrapper {
                margin-left: 0;
            }
            .mobile-overlay {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(15, 23, 42, 0.4);
                backdrop-filter: blur(2px);
                z-index: 999;
            }
            .mobile-overlay.show {
                display: block;
            }
            .admin-header {
                padding: 0 1rem;
            }
            .admin-content {
                padding: 1.5rem 1rem;
            }
        }
    </style>
</head>
<body>

    <!-- Mobile Overlay -->
    <div class="mobile-overlay" id="mobileOverlay"></div>

    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <a href="/" class="text-decoration-none d-flex align-items-center">
                <img src="~/images/logo.png" alt="SmartInsurance" height="32" class="me-2 rounded">
                <span class="fs-5 brand-text fw-bold text-secondary">Smart<span class="text-primary">Insurance</span></span>
            </a>
            <!-- Mobile Close Button -->
            <button class="btn btn-sm btn-light d-lg-none ms-auto rounded-circle" id="closeSidebar">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="sidebar-nav">
            <div class="nav-label mt-0">Overview</div>
            <a href="/Admin/Index" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="nav-label">User Management</div>
            <a href="/Admin/Companies" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Companies" ? "active" : "")">
                <i class="bi bi-buildings"></i> Companies
            </a>
            <a href="/Admin/Agents" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Agents" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Agents
            </a>
            <a href="/Admin/Customers" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Customers" ? "active" : "")">
                <i class="bi bi-people"></i> Customers
            </a>

            <div class="nav-label">System</div>
            <a href="/Admin/ManageAds" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "ManageAds" ? "active" : "")">
                <i class="bi bi-megaphone"></i> Advertisements
            </a>
            <a href="/Admin/DocumentVerification" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && (ViewContext.RouteData.Values["Action"]?.ToString() == "DocumentVerification" || ViewContext.RouteData.Values["Action"]?.ToString() == "UserDocuments") ? "active" : "")">
                <i class="bi bi-shield-check"></i> Document Review
            </a>
            <a href="/Admin/InsuranceTypes" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "InsuranceTypes" ? "active" : "")">
                <i class="bi bi-tags"></i> Plan Categories
            </a>
            <a href="/Query/Index" class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Query" ? "active" : "")">
                <i class="bi bi-envelope"></i> Support Queries
            </a>
        </div>

        <div class="mt-auto p-3 border-top border-light">
            <a href="/Auth/Logout" class="sidebar-link text-danger w-100 mb-0 hover-danger">
                <i class="bi bi-box-arrow-right text-danger"></i> Sign Out
            </a>
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div class="admin-wrapper">
        <!-- Top Header -->
        <header class="admin-header d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <button class="btn btn-light d-lg-none me-3" id="openSidebar">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <h5 class="mb-0 fw-bold brand-text text-dark d-none d-md-block">@ViewData["Title"]</h5>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="dropdown">
                    <a class="text-decoration-none d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="text-end d-none d-md-block">
                            <div class="fw-semibold text-dark lh-1 mb-1" style="font-size: 0.9rem;">@User.Identity?.Name</div>
                            <div class="text-muted lh-1" style="font-size: 0.75rem;">System Administrator</div>
                        </div>
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 36px; height: 36px;">
                            <span class="fw-bold">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "A")</span>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2 rounded-3">
                        <li>
                            <div class="px-3 py-2 text-muted small border-bottom mb-1 d-md-none">
                                Signed in as <br/>
                                <strong class="text-dark">@User.Identity?.Name</strong>
                            </div>
                        </li>
                        <li><a class="dropdown-item py-2 text-danger" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Sign out</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="admin-content">
            @RenderBody()
        </main>
        

    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const openBtn = document.getElementById("openSidebar");
            const closeBtn = document.getElementById("closeSidebar");
            const sidebar = document.getElementById("adminSidebar");
            const overlay = document.getElementById("mobileOverlay");

            function toggleSidebar() {
                sidebar.classList.toggle("show");
                overlay.classList.toggle("show");
            }

            if (openBtn) openBtn.addEventListener("click", toggleSidebar);
            if (closeBtn) closeBtn.addEventListener("click", toggleSidebar);
            if (overlay) overlay.addEventListener("click", toggleSidebar);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
