@model SmartInsuranceHub.Models.NewsArticle
@{
    ViewData["Title"] = Model.Title;
    Layout = "_LandingLayout";
}

<style>
    .detail-hero {
        position: relative;
        width: 100%;
        max-height: 440px;
        overflow: hidden;
        background: linear-gradient(135deg, #0a1628 0%, #1a3a6b 50%, #1252b7 100%);
    }
    .detail-hero img {
        width: 100%;
        height: 440px;
        object-fit: cover;
        opacity: 0.85;
    }
    .detail-hero-placeholder {
        width: 100%;
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
        color: rgba(255,255,255,0.2);
    }
    .detail-hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
    }

    .detail-content {
        max-width: 820px;
        margin: -60px auto 60px;
        position: relative;
        z-index: 2;
    }
    .detail-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.1);
        padding: 48px 44px;
    }
    .detail-meta {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }
    .detail-source {
        background: linear-gradient(135deg, #1252b7, #6366f1);
        color: white;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 5px 14px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .detail-date {
        font-size: 0.82rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .detail-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 24px;
        letter-spacing: -0.3px;
    }
    .detail-description {
        font-size: 1.08rem;
        line-height: 1.8;
        color: #475569;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid #e2e8f0;
    }
    .detail-body {
        font-size: 1rem;
        line-height: 1.85;
        color: #334155;
        margin-bottom: 32px;
    }
    .btn-original {
        background: linear-gradient(135deg, #1252b7 0%, #1e40af 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }
    .btn-original:hover {
        background: linear-gradient(135deg, #0e3d8a 0%, #1e3a8a 100%);
        color: white;
        box-shadow: 0 6px 20px rgba(18,82,183,0.3);
        transform: translateY(-2px);
    }
    .btn-back {
        color: #64748b;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
        font-size: 0.9rem;
    }
    .btn-back:hover {
        color: #1252b7;
    }
</style>

<!-- Hero Image -->
<div class="detail-hero">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Title"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="detail-hero-placeholder" style="display:none;">
            <i class="bi bi-newspaper"></i>
        </div>
    }
    else
    {
        <div class="detail-hero-placeholder">
            <i class="bi bi-newspaper"></i>
        </div>
    }
    <div class="detail-hero-overlay"></div>
</div>

<!-- Article Content -->
<div class="container">
    <div class="detail-content">
        <div class="detail-card">
            <!-- Back Link -->
            <a href="@Url.Action("Index", "News")" class="btn-back mb-4 d-inline-block">
                <i class="bi bi-arrow-left"></i> Back to News
            </a>

            <!-- Meta -->
            <div class="detail-meta">
                @if (!string.IsNullOrEmpty(Model.Source))
                {
                    <span class="detail-source">@Model.Source</span>
                }
                @if (!string.IsNullOrEmpty(Model.PublishedAt) && DateTime.TryParse(Model.PublishedAt, out var pubDate))
                {
                    <span class="detail-date">
                        <i class="bi bi-calendar3"></i>
                        @pubDate.ToLocalTime().ToString("MMMM dd, yyyy · hh:mm tt")
                    </span>
                }
            </div>

            <!-- Title -->
            <h1 class="detail-title">@Model.Title</h1>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="detail-description">@Model.Description</p>
            }

            <!-- Content -->
            @if (!string.IsNullOrEmpty(Model.Content))
            {
                <div class="detail-body">
                    @Model.Content
                </div>
            }

            <!-- Actions -->
            <div class="d-flex flex-wrap gap-3 align-items-center">
                @if (!string.IsNullOrEmpty(Model.Url) && Model.Url != "#")
                {
                    <a href="@Model.Url" target="_blank" rel="noopener noreferrer" class="btn-original">
                        <i class="bi bi-box-arrow-up-right"></i> Read Original Article
                    </a>
                }
                <a href="@Url.Action("Index", "News")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Back to All News
                </a>
            </div>
        </div>
    </div>
</div>
