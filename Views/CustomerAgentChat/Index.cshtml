@{
    ViewData["Title"] = "Messages";
    Layout = "_Layout";
    
    var contacts = ViewBag.Contacts as IEnumerable<dynamic>;
    var currentUserId = ViewBag.CurrentUserId as int?;
    var currentUserRole = ViewBag.CurrentUserRole as string;
}

<div class="container-fluid py-0 px-0 h-100" style="min-height: calc(100vh - 150px);">
    <div class="row g-0 h-100 bg-white rounded-4 shadow-sm overflow-hidden" style="border: 1px solid var(--border-color);">
        
        <!-- Sidebar: Contact List -->
        <div class="col-md-4 col-lg-3 border-end h-100 d-flex flex-column bg-light">
            <div class="p-3 border-bottom bg-white d-flex align-items-center justify-content-between">
                <h5 class="fw-bold mb-0">Messages</h5>
                <span class="badge bg-primary rounded-pill">@(contacts?.Count() ?? 0)</span>
            </div>
            
            <div class="p-2 border-bottom bg-white">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0 ps-0" placeholder="Search contacts...">
                </div>
            </div>

            <div class="contact-list flex-grow-1 overflow-auto p-2" id="contactList">
                @if (contacts != null && contacts.Any())
                {
                    foreach (var contact in contacts)
                    {
                        var contactId = (int)contact.GetType().GetProperty("Id").GetValue(contact);
                        var contactName = (string)contact.GetType().GetProperty("Name").GetValue(contact);
                        var contactRole = (string)contact.GetType().GetProperty("Role").GetValue(contact);
                        var avatar = contact.GetType().GetProperty("Avatar").GetValue(contact) as string;
                        
                        var initials = string.Join("", contactName.Split(' ').Take(2).Select(s => s[0])).ToUpper();

                        <div class="contact-item p-3 mb-2 rounded-3 d-flex align-items-center position-relative" data-id="@contactId" style="cursor: pointer; transition: all 0.2s;">
                            @if (!string.IsNullOrEmpty(avatar))
                            {
                                <img src="@avatar" alt="@contactName" class="rounded-circle me-3" width="45" height="45" style="object-fit:cover;">
                            }
                            else
                            {
                                <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold fs-5" style="width: 45px; height: 45px;">
                                    @initials
                                </div>
                            }
                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-semibold text-truncate pe-2">@contactName</h6>
                                    <small class="text-muted" style="font-size: 0.70rem;">@contactRole</small>
                                </div>
                                <p class="text-muted small mb-0 text-truncate"><i class="bi bi-chat-text me-1"></i> Tap to chat</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-5 text-muted">
                        <i class="bi bi-people fs-1 text-light"></i>
                        <p class="mt-2 small">No @(currentUserRole == "Customer" ? "agents" : "customers") found in your city yet.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Main Chat Area -->
        <div class="col-md-8 col-lg-9 h-100 d-flex flex-column position-relative bg-white" id="mainChatArea">
            
            <!-- Empty State / Placeholder -->
            <div id="chatPlaceholder" class="d-flex flex-column align-items-center justify-content-center h-100 w-100 position-absolute top-0 start-0 z-2 bg-white" style="background: url('/images/chat-bg.png') repeat; background-size: 300px; opacity: 0.95;">
                <div class="bg-white p-4 rounded-circle shadow-sm mb-3">
                    <i class="bi bi-chat-dots text-primary" style="font-size: 3rem;"></i>
                </div>
                <h4 class="text-secondary fw-bold">Select a Contact</h4>
                <p class="text-muted">Choose a conversation from the sidebar to start messaging.</p>
            </div>

            <!-- Active Chat State (Hidden by default) -->
            <div id="activeChatBox" class="d-flex flex-column h-100 d-none">
                <!-- Chat Header -->
                <div class="p-3 border-bottom d-flex align-items-center bg-white shadow-sm z-1">
                    <button class="btn btn-sm btn-light me-2 d-md-none" id="btnBackToContacts">
                        <i class="bi bi-arrow-left"></i>
                    </button>
                    <div class="d-flex align-items-center" id="activeContactInfo">
                        <!-- Filled via JS -->
                    </div>
                </div>

                <!-- Messages Feed -->
                <div class="flex-grow-1 p-3 overflow-auto" id="messagesFeed" style="background-color: #f8fafc;">
                    <!-- Filled via JS -->
                </div>

                <!-- Chat Input Area -->
                <div class="p-3 bg-white border-top shadow-sm z-1">
                    <form id="chatForm" class="d-flex gap-2 align-items-end">
                        <div class="d-flex flex-grow-1 p-1 border rounded-pill bg-light align-items-center">
                            <input type="text" id="chatInput" class="form-control border-0 bg-transparent shadow-none" placeholder="Type a message..." autocomplete="off">
                        </div>
                        <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 45px; height: 45px;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const currentUserId = @(currentUserId ?? 0);
        const currentUserRole = '@currentUserRole';
        let activeContactId = null;

        // Establish SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", function (senderIdStr, senderType, message, timestampStr) {
            const senderId = parseInt(senderIdStr);
            // If the message is from the currently active contact, append it
            if (activeContactId === senderId) {
                appendMessage(message, senderType === currentUserRole, new Date(timestampStr));
            } else {
                // Otherwise, show generic toast notification
                showToast("New Message", "You have a new message from a contact!");
            }
        });

        connection.start().catch(err => console.error("SignalR Connection Error: ", err));

        // UI Interactions
        document.querySelectorAll('.contact-item').forEach(item => {
            item.addEventListener('click', function() {
                // Styling active state
                document.querySelectorAll('.contact-item').forEach(i => i.classList.remove('bg-primary-subtle', 'border-primary'));
                this.classList.add('bg-primary-subtle', 'border-primary');
                
                const contactId = this.getAttribute('data-id');
                const contactName = this.querySelector('h6').innerText;
                const contactRole = this.querySelector('small').innerText;
                const avatarHtml = this.querySelector('.rounded-circle').outerHTML;

                activeContactId = parseInt(contactId);

                // Setup header
                document.getElementById('activeContactInfo').innerHTML = `
                    ${avatarHtml}
                    <div class="ms-3">
                        <h6 class="mb-0 fw-bold">${contactName}</h6>
                        <small class="text-success"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> Online</small>
                    </div>
                `;

                // Toggle views
                document.getElementById('chatPlaceholder').classList.add('d-none');
                document.getElementById('activeChatBox').classList.remove('d-none');
                
                // Mobile handling
                if(window.innerWidth < 768) {
                    document.querySelector('.col-md-4').classList.add('d-none');
                    document.getElementById('mainChatArea').classList.remove('d-none');
                }

                // Load History
                loadChatHistory(activeContactId);
            });
        });

        document.getElementById('btnBackToContacts')?.addEventListener('click', () => {
            document.querySelector('.col-md-4').classList.remove('d-none');
            document.getElementById('mainChatArea').classList.add('d-none');
        });

        // Chat History & Sending
        async function loadChatHistory(contactId) {
            const container = document.getElementById('messagesFeed');
            container.innerHTML = '<div class="text-center my-5"><div class="spinner-border text-primary spinner-border-sm"></div></div>';
            
            try {
                const res = await fetch(`/api/customeragentchat/history/${contactId}`);
                if (res.ok) {
                    const messages = await res.json();
                    container.innerHTML = '';
                    if(messages.length === 0) {
                        container.innerHTML = '<div class="text-center my-5 text-muted small px-4"><span class="badge bg-light text-secondary mb-2">Today</span><p>Start the conversation securely. Messages are end-to-end encrypted.</p></div>';
                    } else {
                        messages.forEach(m => {
                            const isMine = m.sender_type === currentUserRole;
                            appendMessage(m.message_text, isMine, new Date(m.sent_at));
                        });
                    }
                }
            } catch (e) {
                console.error('Error loading history', e);
                container.innerHTML = '<div class="alert alert-danger mx-3 mt-3">Failed to load messages.</div>';
            }
        }

        function appendMessage(text, isMine, dateObj) {
            const container = document.getElementById('messagesFeed');
            
            // Remove empty state text if present
            if(container.querySelector('.text-muted.small')) {
                container.innerHTML = '';
            }

            const wrapper = document.createElement('div');
            wrapper.className = `d-flex mb-3 ${isMine ? 'justify-content-end' : 'justify-content-start'}`;
            
            const timeStr = dateObj.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            const bubble = document.createElement('div');
            bubble.style.maxWidth = "75%";
            
            if (isMine) {
                bubble.className = "bg-primary text-white rounded-4 p-3 shadow-sm";
                bubble.style.borderBottomRightRadius = "4px";
                bubble.innerHTML = `
                    <p class="mb-1" style="word-wrap: break-word;">${text}</p>
                    <div class="text-end text-white-50" style="font-size: 0.70rem;">
                        ${timeStr} <i class="bi bi-check2-all ms-1"></i>
                    </div>
                `;
            } else {
                bubble.className = "bg-white text-dark rounded-4 p-3 shadow-sm border border-light";
                bubble.style.borderBottomLeftRadius = "4px";
                bubble.innerHTML = `
                    <p class="mb-1" style="word-wrap: break-word;">${text}</p>
                    <div class="text-end text-muted" style="font-size: 0.70rem;">
                        ${timeStr}
                    </div>
                `;
            }

            wrapper.appendChild(bubble);
            container.appendChild(wrapper);
            container.scrollTop = container.scrollHeight;
        }

        // Handle forms
        document.getElementById('chatForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const input = document.getElementById('chatInput');
            const text = input.value.trim();
            if(!text || !activeContactId) return;

            // Optimistic UI update
            const tempDate = new Date();
            appendMessage(text, true, tempDate);
            input.value = '';

            try {
                // Save to DB
                const res = await fetch(`/api/customeragentchat/send/${activeContactId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ messageText: text })
                });

                if (res.ok) {
                    // Send via SignalR Hub to live connected user
                    // Receiver is the contactId
                    connection.invoke("SendMessage", activeContactId.toString(), currentUserRole, text).catch(err => console.error(err));
                }
            } catch(e) {
                console.error("Send failed", e);
            }
        });

        // Simple toast function
        function showToast(title, body) {
            alert(`${title}: ${body}`); // Fallback for simplicity. Ideally uses Bootstrap Toasts
        }
    </script>
    
    <style>
        .contact-item:hover { background-color: var(--bs-light) !important; }
        .bg-primary-subtle { background-color: #cce5ff !important; }
        
        @@media (max-width: 767.98px) {
            .h-100 { height: calc(100vh - 70px) !important; }
            #mainChatArea { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; }
        }
    </style>
}
