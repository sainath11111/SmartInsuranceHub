@{
    ViewData["Title"] = "Terms of Service";
    Layout = "_LandingLayout";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-4" style="font-family: 'Outfit', sans-serif;">Terms of Service</h1>
            <p class="text-muted">Last updated: @DateTime.UtcNow.ToString("MMMM dd, yyyy")</p>
            
            <hr class="my-4" />

            <div class="prose text-secondary" style="font-family: 'Inter', sans-serif; line-height: 1.8;">
                <h4 class="fw-bold text-dark mt-4">1. Acceptance of Terms</h4>
                <p>Welcome to Smart Insurance Hub. By accessing or using our platform, you agree to be bound by these Terms of Service. If you do not agree, please do not use our services.</p>

                <h4 class="fw-bold text-dark mt-4">2. Account Registration</h4>
                <p>Users must provide accurate, current, and complete information during the registration process (including PAN, Aadhaar, and Date of Birth). Accounts are strictly personal and non-transferable. You are responsible for safeguarding your login credentials.</p>

                <h4 class="fw-bold text-dark mt-4">3. Age Restriction</h4>
                <p>You must be at least 18 years of age to register as a Customer or Agent on this platform. We reserve the right to verify your age using government-issued identification.</p>

                <h4 class="fw-bold text-dark mt-4">4. Agent Conduct</h4>
                <p>Registered Agents are required to maintain a valid operational license. Fraudulent misrepresentation of policies, or abusive behavior toward customers via the built-in chat system, will result in immediate termination.</p>

                <h4 class="fw-bold text-dark mt-4">5. Limitation of Liability</h4>
                <p>Smart Insurance Hub acts as a marketplace. We are not liable for the underlying insurance products provided by standard companies, nor for any claims arising between Customers and Insurance Providers.</p>

                <h4 class="fw-bold text-dark mt-4">6. Modifications</h4>
                <p>We reserve the right to modify these terms at any time. Continued use of the platform constitutes your consent to such changes.</p>
            </div>
            
            <div class="mt-5 text-center">
                <a href="/" class="btn btn-primary rounded-pill px-4 shadow-sm">Back to Home</a>
            </div>
        </div>
    </div>
</div>
