@model IEnumerable<SmartInsuranceHub.Models.InsuranceType>
@{
    ViewData["Title"] = "Insurance Plans";
    Layout = "_LandingLayout";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        padding: 5rem 0;
        text-align: center;
        margin-bottom: 3rem;
    }
    .feature-card {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        height: 100%;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
        transition: all 0.3s;
    }
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(13, 110, 253, 0.1);
        border-color: #0d6efd;
    }
    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        background-color: #eff6ff;
        color: #0d6efd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
    }
</style>

<div class="page-header">
    <div class="container">
        <h1 class="display-4 fw-bold">Insurance Coverage</h1>
        <p class="lead opacity-75">Explore the various insurance options designed to fit your life.</p>
    </div>
</div>

<section id="insurance" class="py-5 bg-white">
    <div class="container mb-5">
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-6">
                    <div class="feature-card">
                        <div class="icon-box">
                            <i class="bi @item.icon"></i>
                        </div>
                        <h4 class="fw-bold mb-3">@item.type_name</h4>
                        <p class="text-muted mb-4">@item.description</p>
                        <a href="/Customer/BrowsePlans" class="text-primary text-decoration-none fw-medium">View Benefits <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            }
            @if(!Model.Any())
            {
                <div class="col-12 text-center text-muted">No insurance types available currently. Configure them from the admin panel.</div>
            }
        </div>
    </div>
</section>
