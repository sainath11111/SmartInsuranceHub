@model SmartInsuranceHub.Models.HomeViewModel
@{
    ViewData["Title"] = "Life Insurance & Financial Security";
    Layout = "_LandingLayout";
    var featuredPlans = ViewBag.FeaturedPlans as List<SmartInsuranceHub.Models.InsurancePlan>;
}

<style>
    /* Premium Hero Section */
    .hero-section {
        position: relative;
        padding: 6rem 0 8rem;
        background: radial-gradient(circle at top right, #eef2ff 0%, var(--bg-light) 100%);
        overflow: hidden;
    }
    
    .vector-blob {
        position: absolute;
        z-index: 0;
        filter: blur(90px);
        opacity: 0.5;
    }
    .blob-1 { top: -10%; left: -5%; width: 500px; height: 500px; background: #bfdbfe; border-radius: 50%; }
    .blob-2 { bottom: -10%; right: 10%; width: 600px; height: 600px; background: #ddd6fe; border-radius: 50%; }
    
    .hero-content {
        position: relative;
        z-index: 2;
    }
    
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(37, 99, 235, 0.2);
        border-radius: 50px;
        color: var(--primary-dark);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-sm);
    }
    
    .hero-title {
        font-size: 4.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--secondary);
        letter-spacing: -0.03em;
    }
    
    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 2.5rem;
        max-width: 500px;
    }
    
    .hero-image-wrapper {
        position: relative;
        z-index: 2;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0,0,0,0.15);
        transform: perspective(1000px) rotateY(-5deg) translateY(10px);
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        border: 4px solid white;
    }
    
    .hero-image-wrapper:hover {
        transform: perspective(1000px) rotateY(0deg) translateY(0px) scale(1.02);
    }
    
    /* Stats Section Floating */
    .stats-container {
        position: relative;
        z-index: 10;
        margin-top: -5rem;
    }
    
    .stat-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.8);
        border-radius: 20px;
        padding: 2.5rem 1rem;
        text-align: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        transition: transform 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-8px);
    }
    
    .stat-number {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 0.25rem;
        line-height: 1;
        background: linear-gradient(135deg, var(--primary) 0%, #60a5fa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .stat-label {
        color: var(--secondary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }

    /* Trust Floating Elements */
    .trust-float {
        position: absolute;
        background: white;
        padding: 1rem 1.5rem;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 3;
        animation: float 6s ease-in-out infinite;
    }
    .trust-1 { top: 10%; right: -20px; animation-delay: 0s; }
    .trust-2 { bottom: 15%; left: -30px; animation-delay: 3s; }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }
    
    /* Sections Formatting */
    .section-header {
        text-align: center;
        margin-bottom: 4rem;
    }
    
    .section-subtitle {
        color: var(--primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
    }
    
    .section-title {
        font-size: 2.75rem;
        font-weight: 800;
        color: var(--secondary);
        line-height: 1.2;
    }
    
    .bg-dots {
        background-image: radial-gradient(var(--border-color) 1px, transparent 1px);
        background-size: 30px 30px;
    }

    /* Ad Carousel Continuous Smooth Scroll */
    .ad-marquee {
        overflow: hidden;
        white-space: nowrap;
        display: flex;
        gap: 2rem;
        padding: 1rem 0;
    }
    .ad-marquee-content {
        display: flex;
        animation: marquee 30s linear infinite;
        gap: 2rem;
    }
    .ad-marquee-content:hover {
        animation-play-state: paused;
    }
    @@keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); } /* Scrolls exactly half way assuming content is exactly duplicated once */
    }

    .ad-card {
        width: 380px;
        flex-shrink: 0;
        border-radius: 20px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        background: white;
        transition: transform 0.3s;
    }
    .ad-card:hover { transform: translateY(-5px); }

    @@media (max-width: 992px) {
        .hero-title { font-size: 3.2rem; }
        .hero-image-wrapper { transform: none; margin-top: 3rem; border-width: 2px; }
        .hero-image-wrapper:hover { transform: none; }
        .trust-float { display: none; }
    }
</style>

<!-- ==============================================
     HERO SECTION
     ============================================== -->
<section class="hero-section">
    <div class="vector-blob blob-1"></div>
    <div class="vector-blob blob-2"></div>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content pe-lg-5" data-aos="fade-right">
                <div class="hero-badge">
                    <span class="badge bg-primary rounded-pill"><i class="bi bi-star-fill text-warning me-1"></i>India's #1</span>
                    Digital Insurance Aggregator
                </div>
                <h1 class="hero-title">
                    Compare & Buy <br>
                    <span class="text-gradient">Insurance</span> Instantly.
                </h1>
                <p class="hero-subtitle">
                    Discover comprehensive policies from top-rated companies. Zero paperwork, unbiased advice, and instant cover for you and your family.
                </p>
                
                <div class="d-flex flex-wrap gap-3">
                    <a href="/Auth/RegisterCustomer" class="btn btn-brand btn-lg rounded-pill px-4">
                        Get Insured Now <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a href="/insurance" class="btn btn-outline-smart btn-lg rounded-pill px-4 bg-white">
                        <i class="bi bi-search me-2"></i> Compare Plans
                    </a>
                </div>
                
                <div class="mt-5 d-flex align-items-center gap-3">
                    <div class="d-flex" style="margin-left: 10px;">
                        <img src="https://ui-avatars.com/api/?name=JS&background=random" class="rounded-circle border border-2 border-white ms-n3" style="width:40px;height:40px" />
                        <img src="https://ui-avatars.com/api/?name=AK&background=random" class="rounded-circle border border-2 border-white shadow-sm" style="width:40px;height:40px; margin-left:-15px;" />
                        <img src="https://ui-avatars.com/api/?name=RP&background=random" class="rounded-circle border border-2 border-white shadow-sm" style="width:40px;height:40px; margin-left:-15px;" />
                    </div>
                    <div>
                        <div class="d-flex text-warning fs-6">
                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                        </div>
                        <small class="text-muted fw-bold">Trusted by 1M+ Customers</small>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 position-relative mt-5 mt-lg-0" data-aos="fade-left" data-aos-delay="200">
                <div class="trust-float trust-1">
                    <div class="rounded-circle bg-success bg-opacity-10 text-success p-2 fs-4 lh-1"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <strong class="d-block lh-1 mb-1">100% Secure</strong>
                        <small class="text-muted">IRDAI Approved</small>
                    </div>
                </div>
                <div class="trust-float trust-2">
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary p-2 fs-4 lh-1"><i class="bi bi-lightning-charge"></i></div>
                    <div>
                        <strong class="d-block lh-1 mb-1">Instant Cover</strong>
                        <small class="text-muted">Zero Paperwork</small>
                    </div>
                </div>
                <div class="hero-image-wrapper">
                    <!-- High quality illustrative image -->
                    <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1600&q=100" alt="Family Security" class="img-fluid w-100 rounded shadow-lg" style="object-fit: cover; height: 500px;" loading="lazy" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==============================================
     STATS SECTION
     ============================================== -->
<section class="stats-container">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-10 mt-n5" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-card">
                    <div class="stat-number">@(Model.TotalCompanies)+</div>
                    <div class="stat-label">Insurance Partners</div>
                </div>
            </div>
            <div class="col-md-4 col-10 mt-md-n5" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-card">
                    <div class="stat-number">10k+</div>
                    <div class="stat-label">Active Policies</div>
                </div>
            </div>
            <div class="col-md-4 col-10 mt-md-n5" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-card">
                    <div class="stat-number">₹50Cr+</div>
                    <div class="stat-label">Claims Settled</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==============================================
     SERVICES / CATEGORIES
     ============================================== -->
<section class="py-5 my-5">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div class="section-subtitle">What We Offer</div>
            <h2 class="section-title">Insurance for Every Need</h2>
        </div>
        
        <div class="row g-4">
            @foreach (var type in Model.InsuranceTypes!)
            {
                <div class="col-lg-3 col-md-6" data-aos="fade-up">
                    <div class="card card-modern text-center p-4 border-0 bg-white">
                        <div class="card-icon-wrapper mx-auto mb-4">
                            <i class="bi @(type.icon ?? "bi-shield-check")"></i>
                        </div>
                        <h4 class="card-title-modern">@type.type_name</h4>
                        <p class="text-muted small mb-0">@type.description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ==============================================
     FEATURED PLANS SECTION (NEW)
     ============================================== -->
@if (featuredPlans != null && featuredPlans.Any())
{
<section class="py-5 bg-white bg-dots">
    <div class="container">
        <div class="d-flex align-items-end justify-content-between mb-5" data-aos="fade-up">
            <div>
                <div class="section-subtitle">Best Value</div>
                <h2 class="section-title mb-0">Featured Plans</h2>
            </div>
            <a href="/insurance" class="btn btn-outline-primary rounded-pill px-4 d-none d-md-inline-block">View All Plans</a>
        </div>
        
        <div class="row g-4">
            @foreach(var plan in featuredPlans)
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up">
                    <div class="plan-card">
                        <div class="plan-header bg-light pb-4 border-bottom position-relative">
                            <span class="badge bg-warning position-absolute top-0 end-0 m-3 px-3 py-2 text-dark rounded-pill shadow-sm"><i class="bi bi-star-fill me-1"></i>Top Pick</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold mb-2">@(plan.Company?.company_name ?? "—")</span>
                            <h5 class="fw-bold mb-0" style="font-family: 'Outfit', sans-serif;">@plan.plan_name</h5>
                        </div>
                        <div class="plan-body pt-4">
                            <div class="plan-price mb-4 text-center">
                                ₹@plan.premium_amount.ToString("N0") <small>/yr</small>
                            </div>
                            <div class="plan-stat">
                                <span><i class="bi bi-shield-check me-1"></i>Coverage</span>
                                <span>₹@plan.coverage_amount.ToString("N0")</span>
                            </div>
                            <div class="plan-stat">
                                <span><i class="bi bi-calendar3 me-1"></i>Duration</span>
                                <span>@plan.duration_months Mos</span>
                            </div>
                            <p class="text-muted small mt-3 text-center mb-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @(plan.description ?? "Comprehensive long-term coverage.")
                            </p>
                        </div>
                        <div class="plan-footer text-center">
                            <a href="/Customer/BrowsePlans" class="btn btn-primary-smart w-100 rounded-pill py-2">Compare & Buy</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- ==============================================
     SPONSORED ADVERTISEMENTS (Continuous Marquee)
     ============================================== -->
@if (Model.Advertisements != null && Model.Advertisements.Any())
{
    var adPlanNames = ViewBag.AdPlanNames as Dictionary<string, string> ?? new Dictionary<string, string>();
    
    <section class="py-5" style="background: var(--bg-light);">
        <div class="container mb-4">
            <div class="section-subtitle text-center">Promoted By Partners</div>
            <h2 class="section-title text-center">Special Offers & Sponsors</h2>
        </div>

        <div class="ad-marquee" data-aos="fade-up">
            <!-- Double the content to create infinite scroll effect without jumping -->
            <div class="ad-marquee-content">
                @foreach (var loop in new[] { 1, 2 }) 
                {
                    @foreach (var ad in Model.Advertisements)
                    {
                        var planNameKey = $"{ad.plan_id}_{ad.company_id}";
                        var pName = adPlanNames.ContainsKey(planNameKey) ? adPlanNames[planNameKey] : "Featured Plan";

                        <div class="ad-card">
                            <img src="/api/avatar/@ad.banner_url" 
                                 class="w-100 placeholder-wave bg-light" 
                                 style="height: 180px; object-fit: contain; padding: 0.5rem;" 
                                 alt="@ad.Company?.company_name Advertisement"
                                 onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80';" />
                            
                            <div class="p-4">
                                <span class="badge bg-secondary mb-2">@ad.Company?.company_name</span>
                                <h5 class="fw-bold text-dark mb-1">@ad.title</h5>
                                <p class="text-muted small mb-3">@pName</p>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-primary fw-bold" style="font-size: 0.85rem;"><i class="bi bi-tag-fill me-1"></i>Sponsored Offer</span>
                                    <a href="/Customer/BrowsePlans" class="btn btn-sm btn-outline-primary rounded-pill px-3">View Offer</a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}

<!-- ==============================================
     CTA SECTION
     ============================================== -->
<section class="py-5 position-relative text-white" style="background: var(--secondary); margin-bottom: -1px;">
    <!-- Abstract background -->
    <div style="position:absolute; top:0;left:0;right:0;bottom:0; opacity:0.1; background-image: radial-gradient(circle at center, #ffffff 1px, transparent 1px); background-size: 40px 40px;"></div>
    
    <div class="container position-relative z-1 py-5" data-aos="fade-up">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h2 class="display-5 fw-bold mb-4">Ready to Secure Your Future?</h2>
                <p class="lead mb-5 text-white-50">Join thousands of Indians who have already chosen SmartInsurance for their peace of mind. Get a quote in 2 minutes.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/Auth/RegisterCustomer" class="btn btn-primary-smart btn-lg rounded-pill px-5">Get Started Now</a>
                    <a href="/insurance" class="btn btn-outline-light btn-lg rounded-pill px-5">Explore Plans</a>
                </div>
            </div>
        </div>
    </div>
</section>
