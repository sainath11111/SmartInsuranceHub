@model SmartInsuranceHub.Models.HomeViewModel
@{
    ViewData["Title"] = "Life Insurance & Financial Security";
    Layout = "_LandingLayout";
}

<style>
    /* Premium Hero Section */
    .hero-section {
        position: relative;
        padding: 5rem 0 7rem;
        background: linear-gradient(135deg, var(--bg-light) 0%, #eef2ff 100%);
        overflow: hidden;
    }
    
    .vector-blob {
        position: absolute;
        z-index: 0;
        filter: blur(80px);
        opacity: 0.6;
    }
    .blob-1 { top: -10%; left: -5%; width: 400px; height: 400px; background: #bfdbfe; border-radius: 50%; }
    .blob-2 { bottom: -10%; right: -5%; width: 500px; height: 500px; background: #ddd6fe; border-radius: 50%; }
    
    .hero-content {
        position: relative;
        z-index: 2;
    }
    
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: white;
        border: 1px solid rgba(37, 99, 235, 0.2);
        border-radius: 50px;
        color: var(--primary-dark);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-sm);
    }
    
    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--secondary);
        letter-spacing: -0.03em;
    }
    
    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }
    
    .hero-image-wrapper {
        position: relative;
        z-index: 2;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0,0,0,0.12);
        transform: perspective(1000px) rotateY(-5deg) translateY(20px);
        transition: transform 0.5s ease;
    }
    
    .hero-image-wrapper:hover {
        transform: perspective(1000px) rotateY(0deg) translateY(0px);
    }
    
    /* Stats Section Floating */
    .stats-container {
        position: relative;
        z-index: 10;
        margin-top: -4rem;
    }
    
    .stat-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.5);
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        transition: transform 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
    }
    
    .stat-number {
        font-size: 3rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 0.25rem;
        line-height: 1;
    }
    
    .stat-label {
        color: var(--secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }
    
    /* Sections Formatting */
    .section-header {
        text-align: center;
        margin-bottom: 4rem;
    }
    
    .section-subtitle {
        color: var(--primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
    }
    
    .section-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--secondary);
    }
    
    .bg-dots {
        background-image: radial-gradient(var(--border-color) 1px, transparent 1px);
        background-size: 30px 30px;
    }

    @@media (max-width: 992px) {
        .hero-title { font-size: 3rem; }
        .hero-image-wrapper { transform: none; margin-top: 3rem; }
        .hero-image-wrapper:hover { transform: none; }
    }
</style>

<!-- Hero Section -->
<section class="hero-section">
    <div class="vector-blob blob-1"></div>
    <div class="vector-blob blob-2"></div>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content pe-lg-5">
                <div class="hero-badge">
                    <span class="badge bg-primary rounded-pill">New</span>
                    100% Digital Insurance Platform
                </div>
                <h1 class="hero-title">
                    Protect what <br>
                    matters <span class="text-gradient">most.</span>
                </h1>
                <p class="hero-subtitle">
                    Experience the future of insurance. Transparent coverage, competitive rates, and seamless claims—all from one highly secure dashboard.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#insurance" class="btn btn-brand btn-lg py-3 px-4 fw-bold shadow-lg">Get Covered Today <i class="bi bi-arrow-right ms-2"></i></a>
                    <a href="/about" class="btn btn-outline-smart btn-lg py-3 px-4 fw-bold bg-white">How it Works</a>
                </div>
                
                <div class="mt-5 d-flex align-items-center gap-3">
                    <div class="d-flex">
                        <img src="https://i.pravatar.cc/100?img=1" alt="User" class="rounded-circle border border-2 border-white" width="40" height="40" style="margin-right: -10px; z-index: 3;">
                        <img src="https://i.pravatar.cc/100?img=2" alt="User" class="rounded-circle border border-2 border-white" width="40" height="40" style="margin-right: -10px; z-index: 2;">
                        <img src="https://i.pravatar.cc/100?img=3" alt="User" class="rounded-circle border border-2 border-white" width="40" height="40" style="z-index: 1;">
                    </div>
                    <div>
                        <div class="d-flex text-warning">
                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                        </div>
                        <div class="small fw-medium text-muted">Trusted by 10,000+ customers</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image-wrapper">
                    <img src="https://static.vecteezy.com/system/resources/thumbnails/025/025/618/small_2x/insurance-with-hands-protect-crisis-business-risk-control-and-plan-and-strategies-to-run-prevent-businesses-deposits-medical-expenses-rent-family-care-travel-transport-communication-accident-free-photo.JPG" alt="Modern Family Security" class="img-fluid w-100" style="object-fit: cover; height: 550px;" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Sponsored Ads Carousel -->
@if (Model.Advertisements.Any())
{
    var adPlanNames = ViewBag.AdPlanNames as Dictionary<string, string> ?? new Dictionary<string, string>();
    <style>
        .ad-carousel-section {
            padding: 2rem 0 0;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            overflow: hidden;
        }
        .ad-carousel-track {
            display: flex;
            gap: 1.5rem;
            animation: scrollAds 30s linear infinite;
            width: max-content;
        }
        .ad-carousel-track:hover {
            animation-play-state: paused;
        }
        @@keyframes scrollAds {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .ad-card {
            flex: 0 0 360px;
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            transition: transform 0.4s cubic-bezier(.25,.8,.25,1), box-shadow 0.4s ease;
            cursor: pointer;
            background: white;
        }
        .ad-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 60px rgba(37,99,235,0.15);
        }
        .ad-card-banner {
            height: 200px;
            overflow: hidden;
            position: relative;
        }
        .ad-card-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        .ad-card:hover .ad-card-banner img {
            transform: scale(1.1);
        }
        .ad-card-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60%;
            background: linear-gradient(transparent, rgba(0,0,0,0.7));
        }
        .ad-sponsored {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            color: #f59e0b;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .ad-priority {
            position: absolute;
            top: 12px;
            right: 12px;
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            color: white;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
        }
        .ad-card-body {
            padding: 1.25rem;
        }
        .ad-card-title {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--secondary);
            margin-bottom: 0.25rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .ad-card-company {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 0.75rem;
        }
        .ad-card-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 20px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(37,99,235,0.3);
        }
        .ad-card-btn:hover {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            transform: translateX(3px);
            color: white;
            box-shadow: 0 6px 20px rgba(37,99,235,0.4);
        }
        @@media (max-width: 768px) {
            .ad-card { flex: 0 0 280px; }
            .ad-card-banner { height: 160px; }
        }
    </style>

    <section class="ad-carousel-section">
        <div class="container mb-3">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-stars me-1"></i>Featured Promotions</span>
                <div class="flex-grow-1" style="height: 1px; background: linear-gradient(90deg, #e2e8f0, transparent);"></div>
            </div>
        </div>
        <div style="overflow: hidden; padding: 0.5rem 0 2rem;">
            <div class="ad-carousel-track" id="adCarousel">
                @* Duplicate ads for seamless infinite scroll *@
                @for (int repeat = 0; repeat < 2; repeat++)
                {
                    @foreach (var ad in Model.Advertisements)
                    {
                        var key = $"{ad.plan_id}_{ad.company_id}";
                        var pName = adPlanNames.ContainsKey(key) ? adPlanNames[key] : "Insurance Plan";
                        var banner = !string.IsNullOrWhiteSpace(ad.banner_url) ? ad.banner_url : "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=800&q=80";
                        <div class="ad-card">
                            <div class="ad-card-banner">
                                <img src="@banner" alt="@ad.title" loading="lazy" />
                                <div class="ad-card-overlay"></div>
                                <span class="ad-sponsored"><i class="bi bi-megaphone-fill me-1"></i>Sponsored</span>
                                @if (ad.amount_paid >= 1000)
                                {
                                    <span class="ad-priority"><i class="bi bi-lightning-fill me-1"></i>Premium</span>
                                }
                            </div>
                            <div class="ad-card-body">
                                <div class="ad-card-title">@ad.title</div>
                                <div class="ad-card-company">
                                    <i class="bi bi-building me-1"></i>@(ad.Company?.company_name ?? "Insurance Co.") · <i class="bi bi-shield-check me-1"></i>@pName
                                </div>
                                <a href="/Customer/BrowsePlans" class="ad-card-btn">
                                    View Plan <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}

<!-- Stats Section -->
<section class="stats-container">
    <div class="container">
        <div class="row justify-content-center g-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number"><span class="counter" data-target="@Model.TotalCompanies">0</span>+</div>
                    <div class="stat-label">Partner Companies</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number"><span class="counter" data-target="@Model.TotalCustomers">0</span>K</div>
                    <div class="stat-label">Happy Customers</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number"><span class="counter" data-target="@Model.YearsExperience">0</span>+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Coverage / Insurance Types -->
<section id="insurance" class="py-5 bg-white mt-5">
    <div class="container py-4">
        <div class="section-header">
            <div class="section-subtitle">Tailored Solutions</div>
            <h2 class="section-title">Insurance that fits your life</h2>
            <p class="text-muted mt-3 mx-auto" style="max-width: 600px;">We’ve curated the best coverage options so you don’t have to compromise. Choose the perfect plan for you and your loved ones.</p>
        </div>
        
        <div class="row g-4 justify-content-center">
            @foreach (var item in Model.InsuranceTypes)
            {
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card card-modern border-0 p-4">
                        <div class="card-icon-wrapper">
                            <i class="bi @item.icon"></i>
                        </div>
                        <h4 class="card-title-modern">@item.type_name</h4>
                        <p class="text-muted small mb-4 flex-grow-1">@item.description</p>
                        <a href="/Customer/BrowsePlans" class="fw-bold text-decoration-none d-flex align-items-center gap-2" style="color: var(--primary);">
                            Explore Plans <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
            @if(!Model.InsuranceTypes.Any())
            {
                <div class="col-12 text-center text-muted">No insurance types available currently. Configure them from the admin panel.</div>
            }
        </div>
    </div>
</section>

<!-- Trusted Partners -->
<section id="companies" class="py-5 bg-light bg-dots">
    <div class="container py-5">
        <div class="section-header">
            <div class="section-subtitle">Premium Carriers</div>
            <h2 class="section-title">Backed by the best</h2>
        </div>
        
        <div class="row g-4 justify-content-center">
            @foreach (var company in Model.Companies)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card card-modern p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 mx-auto" style="width: 80px; height: 80px; background: rgba(37, 99, 235, 0.05); color: var(--primary);">
                            <i class="bi @company.Icon fs-1"></i>
                        </div>
                        <h4 class="fw-bold text-dark mb-2">@company.Name</h4>
                        <p class="text-muted small mb-4">@company.Description</p>
                        <div class="mt-auto">
                            <span class="badge bg-light text-primary border px-3 py-2 rounded-pill"><i class="bi bi-shield-check me-1"></i> @company.TotalPolicies Verified Policies</span>
                        </div>
                    </div>
                </div>
            }
            @if(!Model.Companies.Any())
            {
                <div class="col-12 text-center text-muted">Register and approve an insurance company to see them listed here.</div>
            }
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 position-relative overflow-hidden" style="background: var(--secondary);">
    <div class="vector-blob blob-1" style="background: rgba(37, 99, 235, 0.2); right: -10%; left: auto;"></div>
    <div class="container py-5 position-relative z-3 text-center">
        <h2 class="text-white fw-bold mb-4" style="font-size: 3rem;">Ready to secure your future?</h2>
        <p class="text-white-50 fs-5 mb-5 mx-auto" style="max-width: 600px;">Join thousands of others who have found reliable protection through our tailored digital insurance options.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="/Auth/RegisterCustomer" class="btn btn-brand btn-lg fw-bold shadow-lg">Sign Up Now</a>
            <a href="/Customer/SubmitQuery" class="btn btn-outline-light btn-lg fw-bold px-4">Contact Agent</a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.counter');
        const speed = 50; 

        const animateCounters = () => {
            counters.forEach(counter => {
                const updateCount = () => {
                    const target = +counter.getAttribute('data-target');
                    const count = +counter.innerText;
                    
                    const inc = target / speed;

                    if (count < target && target > 0) {
                        counter.innerText = Math.ceil(count + inc);
                        setTimeout(updateCount, 40);
                    } else {
                        counter.innerText = target;
                    }
                };
                updateCount();
            });
        };

        const observer = new IntersectionObserver((entries) => {
            if(entries[0].isIntersecting) {
                animateCounters();
                observer.disconnect();
            }
        }, { threshold: 0.1 });

        const statsSection = document.querySelector('.stats-container');
        if (statsSection) {
            observer.observe(statsSection);
        } else {
            animateCounters();
        }
    });
</script>
}
