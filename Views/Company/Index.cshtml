@{
    ViewData["Title"] = "Company Dashboard";
}

<style>
    .co-kpi {
        background: #fff; border-radius: 18px; border: 1px solid rgba(226,232,240,0.8);
        padding: 1.6rem 1.5rem; display: flex; align-items: center; gap: 1.2rem;
        box-shadow: 0 4px 24px rgba(30,64,175,0.04);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        position: relative; overflow: hidden; height: 100%;
    }
    .co-kpi::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 18px 18px 0 0;
    }
    .co-kpi.blue::before  { background: linear-gradient(90deg,#2563eb,#60a5fa); }
    .co-kpi.green::before { background: linear-gradient(90deg,#10b981,#34d399); }
    .co-kpi.sky::before   { background: linear-gradient(90deg,#0ea5e9,#38bdf8); }
    .co-kpi.amber::before { background: linear-gradient(90deg,#f59e0b,#fcd34d); }
    .co-kpi:hover { transform: translateY(-5px); box-shadow: 0 12px 36px rgba(30,64,175,0.10); }
    .co-icon { width: 54px; height: 54px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
    .co-lbl { font-size: 0.775rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; margin-bottom: 2px; }
    .co-val { font-size: 1.9rem; font-weight: 800; color: #0f172a; font-family: 'Outfit', sans-serif; line-height: 1; }

    .co-banner {
        background: linear-gradient(135deg, #312e81 0%, #4f46e5 60%, #818cf8 100%);
        border-radius: 20px; padding: 2rem 2.5rem; color: #fff;
        position: relative; overflow: hidden; margin-bottom: 1.75rem;
    }
    .co-banner::after {
        content: ''; position: absolute; right: -60px; top: -60px;
        width: 220px; height: 220px; border-radius: 50%; background: rgba(255,255,255,0.06);
    }

    .co-action {
        background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
        padding: 1.25rem; text-decoration: none; color: #0f172a;
        display: flex; align-items: center; gap: 1rem;
        transition: all 0.25s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .co-action:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(79,70,229,0.12); border-color: #c7d2fe; color: #312e81; }
    .co-action-icon { width: 50px; height: 50px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; flex-shrink: 0; }
    .section-eyebrow { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; }
    .section-title { font-size: 1.15rem; font-weight: 800; font-family: 'Outfit', sans-serif; color: #0f172a; margin: 0; }
</style>

<!-- Banner -->
<div class="co-banner" data-aos="fade-down">
    <div class="row align-items-center position-relative" style="z-index:1;">
        <div class="col-md-8">
            <p class="mb-1 fw-semibold" style="color:rgba(255,255,255,0.7); font-size:0.875rem;">Company Control Panel</p>
            <h2 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif; font-size:1.75rem;">Welcome, @User.Identity?.Name 👋</h2>
            <p class="mb-0" style="color:rgba(255,255,255,0.75); font-size:0.95rem;">Your business metrics and operations hub.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a href="/Insurance/CreatePlan" class="btn fw-bold px-4 py-2 rounded-pill shadow-sm"
               style="background:#fff; color:#312e81; font-size:0.9rem;">
                <i class="bi bi-plus-circle-fill me-2"></i>Create New Plan
            </a>
        </div>
    </div>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="50">
        <div class="co-kpi blue">
            <div class="co-icon" style="background:rgba(37,99,235,0.10); color:#2563eb;">
                <i class="bi bi-person-badge-fill"></i>
            </div>
            <div>
                <p class="co-lbl mb-0">Agents</p>
                <p class="co-val">@ViewBag.TotalAgents</p>
                <small class="text-muted">Active</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="100">
        <div class="co-kpi green">
            <div class="co-icon" style="background:rgba(16,185,129,0.10); color:#10b981;">
                <i class="bi bi-shield-fill-check"></i>
            </div>
            <div>
                <p class="co-lbl mb-0">Plans</p>
                <p class="co-val">@ViewBag.TotalPlans</p>
                <small class="text-muted">Active offerings</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="150">
        <div class="co-kpi sky">
            <div class="co-icon" style="background:rgba(14,165,233,0.10); color:#0ea5e9;">
                <i class="bi bi-file-earmark-text-fill"></i>
            </div>
            <div>
                <p class="co-lbl mb-0">Policies</p>
                <p class="co-val">@ViewBag.TotalPolicies</p>
                <small class="text-muted">Issued</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="200">
        <div class="co-kpi amber">
            <div class="co-icon" style="background:rgba(245,158,11,0.10); color:#f59e0b;">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div>
                <p class="co-lbl mb-0">Revenue</p>
                <p class="co-val" style="font-size:1.4rem;">₹@ViewBag.TotalSales</p>
                <small class="text-muted">Total collected</small>
            </div>
        </div>
    </div>
</div>

<!-- Content -->
<div class="row g-4">
    <div class="col-lg-6" data-aos="fade-up">
        <div class="card-modern p-4 h-100">
            <p class="section-eyebrow mb-0"><i class="bi bi-lightning-charge-fill me-1 text-primary"></i>Operations</p>
            <h5 class="section-title mb-4">Quick Links</h5>
            <div class="d-flex flex-column gap-3">
                <a href="/Company/PendingPayments" class="co-action">
                    <div class="co-action-icon" style="background:rgba(245,158,11,0.10); color:#f59e0b;">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <div>
                        <p class="fw-bold mb-0">Pending Payments</p>
                        <small class="text-muted">Review outstanding premium collections</small>
                    </div>
                    <i class="bi bi-chevron-right text-muted ms-auto"></i>
                </a>
                <a href="/Insurance/CreatePlan" class="co-action">
                    <div class="co-action-icon" style="background:rgba(37,99,235,0.10); color:#2563eb;">
                        <i class="bi bi-plus-circle-fill"></i>
                    </div>
                    <div>
                        <p class="fw-bold mb-0">Create New Plan</p>
                        <small class="text-muted">Launch a new insurance product</small>
                    </div>
                    <i class="bi bi-chevron-right text-muted ms-auto"></i>
                </a>
                <a href="/Company/Agents" class="co-action">
                    <div class="co-action-icon" style="background:rgba(124,58,237,0.10); color:#7c3aed;">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <div>
                        <p class="fw-bold mb-0">My Agents</p>
                        <small class="text-muted">Manage your agent network</small>
                    </div>
                    <i class="bi bi-chevron-right text-muted ms-auto"></i>
                </a>
                <a href="/Insurance/Index" class="co-action">
                    <div class="co-action-icon" style="background:rgba(16,185,129,0.10); color:#10b981;">
                        <i class="bi bi-grid"></i>
                    </div>
                    <div>
                        <p class="fw-bold mb-0">Our Plans</p>
                        <small class="text-muted">View and manage all insurance plans</small>
                    </div>
                    <i class="bi bi-chevron-right text-muted ms-auto"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-6" data-aos="fade-left">
        <div class="card-modern p-4 h-100">
            <p class="section-eyebrow mb-0"><i class="bi bi-bar-chart-fill me-1 text-secondary"></i>Performance</p>
            <h5 class="section-title mb-4">Business Overview</h5>

            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1">
                    <small class="fw-semibold">Agent Utilisation</small>
                    @{
                        int agentCap = Math.Max((int)(ViewBag.TotalAgents ?? 1) * 5, 1);
                        int agentPct = Math.Min(((int)(ViewBag.TotalPolicies ?? 0) * 100 / agentCap), 100);
                    }
                    <small class="text-muted">@agentPct%</small>
                </div>
                <div class="progress" style="height:8px; border-radius:99px;">
                    <div class="progress-bar" style="width:@agentPct%; background:linear-gradient(90deg,#4f46e5,#818cf8); border-radius:99px;"></div>
                </div>
                <small class="text-muted d-block mt-1">@ViewBag.TotalPolicies policies issued across @ViewBag.TotalAgents agents</small>
            </div>

            <div class="row g-3">
                <div class="col-6">
                    <div class="p-3 rounded-3 text-center" style="background:#f8fafc; border:1px solid #e2e8f0;">
                        <i class="bi bi-shield-fill-check fs-2 mb-2 d-block" style="color:#10b981;"></i>
                        <h5 class="fw-bold mb-0" style="font-family:'Outfit',sans-serif; color:#10b981;">@ViewBag.TotalPlans</h5>
                        <small class="text-muted">Active Plans</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-3 text-center" style="background:#f8fafc; border:1px solid #e2e8f0;">
                        <i class="bi bi-currency-rupee fs-2 mb-2 d-block" style="color:#f59e0b;"></i>
                        <h5 class="fw-bold mb-0" style="font-family:'Outfit',sans-serif; color:#f59e0b;">₹@ViewBag.TotalSales</h5>
                        <small class="text-muted">Revenue</small>
                    </div>
                </div>
            </div>

            <div class="mt-4 p-3 rounded-3 d-flex align-items-center gap-3"
                 style="background:linear-gradient(135deg,#eff6ff,#dbeafe); border:1px solid #93c5fd;">
                <i class="bi bi-megaphone-fill fs-4" style="color:#3b82f6;"></i>
                <div>
                    <strong class="text-dark d-block" style="font-size:0.875rem;">Boost Visibility</strong>
                    <small class="text-muted">
                        <a href="/Advertisement/MyAds" class="text-primary text-decoration-none fw-semibold">Manage Advertisements</a> to attract more customers.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
