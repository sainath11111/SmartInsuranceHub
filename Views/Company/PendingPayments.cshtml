@model IEnumerable<SmartInsuranceHub.Models.Payment>
@{
    ViewData["Title"] = "Pending Payments";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-wallet2 text-warning me-2"></i>Pending Payments</h2>
        <p class="text-muted mb-0">Review customer premium payments to activate insurance policies.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-2">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-check-circle text-success fs-1"></i>
                <h4 class="mt-3">All caught up!</h4>
                <p class="text-muted">There are no pending payments requiring approval right now.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Payment ID</th>
                            <th>Customer & Details</th>
                            <th>Policy & Agent</th>
                            <th>Amount Paid</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td><span class="fw-bold text-muted">#@payment.payment_id</span><br /><small>@payment.payment_date.ToString("MMM dd, yyyy")</small></td>
                                <td>
                                    <strong>@payment.Policy?.Customer?.full_name</strong><br />
                                    <small class="text-muted">@payment.Policy?.Customer?.email</small><br />
                                    <small class="text-muted">Phone: @payment.Policy?.Customer?.phone</small>
                                </td>
                                <td>
                                    <strong>@payment.Policy?.InsurancePlan?.plan_name</strong><br/>
                                    <small class="text-muted"><i class="bi bi-person-badge me-1"></i>Sold by: @payment.Agent?.full_name</small>
                                </td>
                                <td><strong class="text-success">₹@payment.amount.ToString("N0")</strong><br/><span class="badge bg-secondary">@payment.method</span></td>
                                <td>
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Under Review</span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <form asp-action="ApprovePayment" method="post">
                                            <input type="hidden" name="id" value="@payment.payment_id" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold"><i class="bi bi-check-lg"></i> Approve</button>
                                        </form>
                                        <form asp-action="RejectPayment" method="post" onsubmit="return submitReject(this);">
                                            <input type="hidden" name="id" value="@payment.payment_id" />
                                            <input type="hidden" name="reason" value="" class="reason-input" />
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold"><i class="bi bi-x-lg"></i> Reject</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    function submitReject(form) {
        var reason = prompt("Enter the reason for rejecting this payment:");
        if (reason === null) {
            return false; // User clicked Cancel
        }
        if (reason.trim() === '') {
            reason = "Payment was rejected by the company.";
        }
        form.querySelector('.reason-input').value = reason;
        return true;
    }
</script>
